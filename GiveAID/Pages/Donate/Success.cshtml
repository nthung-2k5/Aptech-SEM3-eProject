@page
@model SuccessModel
@{
    ViewData["Title"] = "Donation Successful";
}

<div class="py-20 bg-base-200 min-h-[70vh] flex items-center justify-center">
    <div class="max-w-md mx-auto px-6 text-center">
        <div class="card bg-base-100 shadow-xl border border-base-200">
            <div class="card-body items-center">
                <div class="w-20 h-20 bg-success/10 rounded-full flex items-center justify-center mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-success" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>

                <h1 class="text-3xl font-bold mb-2">Thank You!</h1>
                <p class="text-base-content/80 mb-6">Your generous donation has been processed successfully.</p>

                <div class="bg-base-200 rounded-box p-4 w-full mb-8 text-left border border-base-300">
                    <span class="block text-sm font-semibold opacity-70 mb-1">Transaction ID</span>
                    <span class="block font-mono text-sm break-all font-bold">@Model.TransactionId</span>
                </div>

                <a href="/" class="btn btn-primary w-full">Return Home</a>
            </div>
        </div>
    </div>
</div>
