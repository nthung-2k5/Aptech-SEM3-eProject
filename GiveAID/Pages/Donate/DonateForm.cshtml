@model DonateForm

<form on:submit="@(() => Model.Submit())" class="grid grid-cols-1 lg:grid-cols-[1fr_auto_auto_auto] gap-8">
    <!-- Left Side: Card Information -->
    <div class="card bg-base-100 shadow-2xl border border-base-200">
        <div class="card-body">
            <h2 class="card-title text-3xl font-bold mb-2">Payment Details</h2>
            <p class="text-base-content/70 mb-6">Enter your payment information securely below.</p>

            @if (!string.IsNullOrEmpty(Model.UserFullName))
            {
                <div class="bg-base-200/50 rounded-xl p-4 mb-6 border border-base-300">
                    <h3 class="text-sm font-semibold opacity-70 mb-3 uppercase tracking-wider">Donor Information</h3>
                    <div class="flex flex-col gap-2 text-sm">
                        <div class="flex items-center gap-3">
                            <i class="ph ph-user text-lg opacity-70"></i>
                            <span class="font-medium">@Model.UserFullName</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <i class="ph ph-envelope text-lg opacity-70"></i>
                            <span class="font-medium">@Model.UserEmail</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.UserPhone))
                        {
                            <div class="flex items-center gap-3">
                                <i class="ph ph-phone text-lg opacity-70"></i>
                                <span class="font-medium">@Model.UserPhone</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="w-full mb-4">
                <label class="label">
                    <span class="label-text font-semibold">Cardholder Name</span>
                </label>
                <label class="input w-full">
                    <i class="ph ph-user text-lg opacity-70"></i>
                    <input type="text" asp-for="CardHolderName" bind class="grow" placeholder="John Doe" required/>
                </label>
                <span asp-validation-for="CardHolderName" class="text-error text-xs mt-1 font-medium"></span>
            </div>

            <div class="w-full mb-4">
                <label class="label">
                    <span class="label-text font-semibold">Card Number</span>
                </label>
                <label class="input w-full">
                    <i class="ph ph-credit-card text-lg opacity-70"></i>
                    <input type="text" asp-for="CardNumber" bind placeholder="1234 5678 9101 1121" required pattern="\d{16}" title="Must be exactly 16 digits"/>
                    <div class="flex items-center gap-1 pointer-events-none mr-1">
                        <img src="~/icons/visa.svg" alt="Visa" class="h-4 w-auto" />
                        <img src="~/icons/mastercard.svg" alt="Mastercard" class="h-4 w-auto" />
                    </div>
                </label>
                <span asp-validation-for="CardNumber" class="text-error text-xs mt-1 font-medium"></span>
            </div>

            <div class="grid grid-cols-2 gap-6 mb-6">
                <div class="w-full">
                    <label class="label">
                        <span class="label-text font-semibold">Expiry Date</span>
                    </label>
                    <label class="input w-full">
                        <i class="ph ph-calendar-blank text-lg opacity-70"></i>
                        <input type="text" asp-for="ExpiryDate" bind class="grow" placeholder="MM/YY" required pattern="^(0[1-9]|1[0-2])\/?([0-9]{2})$"/>
                    </label>
                    <span asp-validation-for="ExpiryDate" class="text-error text-xs mt-1 font-medium"></span>
                </div>
                <div class="w-full">
                    <label class="label">
                        <span class="label-text font-semibold">CVV</span>
                    </label>
                    <label class="input w-full">
                        <i class="ph ph-lock-key text-lg opacity-70"></i>
                        <input type="password" asp-for="CVV" bind class="grow" placeholder="123" required pattern="\d{3,4}" value="@Model.CVV"/>
                    </label>
                    <span asp-validation-for="CVV" class="text-error text-xs mt-1 font-medium"></span>
                </div>
            </div>

            <div class="alert alert-success bg-success/10 text-success-content border-success/20 shadow-sm text-sm">
                <i class="ph ph-shield-check text-2xl flex-shrink-0"></i>
                <div>
                    <h3 class="font-bold">Secure Payment</h3>
                    <div class="text-xs">Your transactions are secured with 256-bit encryption.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Side: Donation Summary -->
    <div class="card bg-primary text-primary-content shadow-2xl h-fit">
        <div class="card-body">
            <h2 class="card-title text-2xl font-bold border-b border-primary-content/20 pb-4 mb-4">Donation Summary</h2>

            <div class="bg-primary-content/10 rounded-xl p-5 mb-4 backdrop-blur-sm">
                <div class="text-sm font-medium opacity-80 mb-1">Donating To</div>
                <div class="font-bold text-xl leading-tight">@Model.TargetDescription</div>
            </div>

            @if (Model is { NgoId: not null, Causes.Length: > 0 })
            {
                <div class="mb-5">
                    <label class="block text-sm font-semibold text-primary-content/90 mb-2">
                        <i class="ph ph-tag mr-1"></i> Select a Cause <span class="font-normal opacity-70">(optional)</span>
                    </label>
                    <select asp-for="CauseId" bind class="w-full select text-primary">
                        <option value="">— General Donation —</option>
                        @foreach (var cause in Model.Causes)
                        {
                            <option value="@cause.Id">@cause.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="w-full mb-6">
                <label class="label">
                    <span class="label-text text-primary-content font-semibold text-lg">Amount (USD)</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-2xl font-bold opacity-70">$</span>
                    <label class="input input-lg w-full text-2xl text-primary">
                        <i class="ph-bold ph-currency-dollar text-primary"></i>
                        <input type="number" asp-for="Amount" bind min="1" step="0.01" required class="text-2xl font-bold"/>
                    </label>
                </div>
                <span asp-validation-for="Amount" class="text-error-content bg-error/80 px-2 py-1 rounded text-xs mt-2 font-medium inline-block w-fit"></span>
            </div>

            <div class="flex-grow"></div>

            <div class="divider before:bg-primary-content/20 after:bg-primary-content/20"></div>

            <div class="flex justify-between items-end mb-8">
                <span class="text-lg font-medium opacity-80 mb-1">Total Impact</span>
                <div class="text-right">
                    <div class="text-4xl font-extrabold">@Model.Amount.ToUsCurrencyString()</div>
                </div>
            </div>

            <button type="submit" class="btn bg-base-100 hover:bg-base-200 text-primary border-none btn-lg w-full shadow-xl gap-2 font-bold hover:scale-[1.02] transition-transform">
                <i class="ph ph-heart text-xl"></i>
                Complete Donation
            </button>
            <p class="text-center text-xs opacity-70 mt-4">Thank you for your generosity.</p>
        </div>
    </div>
</form>

