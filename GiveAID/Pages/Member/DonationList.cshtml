@model DonationList

<div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar Filter -->
    <aside class="w-full lg:w-1/4">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 sticky top-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-gray-900">Filters</h2>
                <button type="button" on:click="@(() => Model.ClearFilter())" class="text-sm text-[#1A5C6B] hover:underline cursor-pointer">Clear all</button>
            </div>

            <!-- Time Period Filter -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">Time Period</h3>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="radio" asp-for="Query.TimePeriod" value="all" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">All Time</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" asp-for="Query.TimePeriod" value="30days" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">Last 30 Days</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" asp-for="Query.TimePeriod" value="6months" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">Last 6 Months</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" asp-for="Query.TimePeriod" value="year" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">This Year</span>
                    </label>
                </div>
            </div>

            <!-- Target Type Filter -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">Target Type</h3>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="checkbox" asp-for="Query.TargetNgo" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">NGOs</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" asp-for="Query.TargetProgramme" bind on:change="@(() => Model.ApplyFiltersAsync())" class="h-4 w-4 text-[#1A5C6B] focus:ring-[#1A5C6B] rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-600">Programmes</span>
                    </label>
                </div>
            </div>

            <!-- Amount Range Filter -->
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">Amount Range</h3>
                <div class="flex items-center gap-2">
                    <div class="relative rounded-md shadow-sm w-full">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-gray-500 sm:text-sm">$</span>
                        </div>
                        <input type="number" asp-for="Query.MinAmount" bind:keydown.debounce.500ms on:input="@(() => Model.ApplyFiltersAsync())" class="focus:ring-[#1A5C6B] focus:border-[#1A5C6B] block w-full pl-7 py-2 sm:text-sm border-gray-300 rounded-md" placeholder="Min">
                    </div>
                    <span class="text-gray-500">-</span>
                    <div class="relative rounded-md shadow-sm w-full">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-gray-500 sm:text-sm">$</span>
                        </div>
                        <input type="number" asp-for="Query.MaxAmount" bind:keydown.debounce.500ms on:input="@(() => Model.ApplyFiltersAsync())" class="focus:ring-[#1A5C6B] focus:border-[#1A5C6B] block w-full pl-7 py-2 sm:text-sm border-gray-300 rounded-md" placeholder="Max">
                    </div>
                </div>
            </div>

        </div>
    </aside>

    <!-- Main Content -->
    <main class="w-full lg:w-3/4">
        @if (Model.Donations.Items.Length == 0)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center h-full flex flex-col justify-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#1A5C6B] bg-opacity-10 mb-6 mx-auto">
                    <svg class="w-8 h-8 text-[#1A5C6B]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">No donations found</h3>
                <p class="text-gray-500 mb-8 max-w-md mx-auto">We couldn't find any donations matching your criteria, or you haven't made any yet.</p>
                <div>
                    <a asp-page="/Programmes/Index" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-[#1A5C6B] hover:bg-[#13434e] transition duration-150 ease-in-out shadow-sm hover:shadow">
                        Explore Programmes
                        <svg class="ml-2 -mr-1 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white shadow-sm border border-gray-100 rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50/80">
                            <tr>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    Date
                                </th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    Amount
                                </th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    Target
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            @foreach (var donation in Model.Donations.Items)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors duration-150">
                                    <td class="px-6 py-5 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 flex items-center justify-center rounded-full bg-blue-50 text-[#1A5C6B]">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                                </svg>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-medium text-gray-900">
                                                    @donation.DonationDate.ToString("MMM dd, yyyy")
                                                </div>
                                                <div class="text-xs text-gray-500">
                                                    @donation.DonationDate.ToString("hh:mm tt")
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5 whitespace-nowrap">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-green-50 text-green-700">
                                            $@donation.Amount.ToString("N2")
                                        </span>
                                    </td>
                                    <td class="px-6 py-5 whitespace-nowrap">
                                        @if (donation.Target.TryPickT0(out var ngo, out var programme))
                                        {
                                            <a asp-page="/Ngo/Details" asp-route-id="@ngo.Ngo.Id" class="group flex flex-col">
                                                <span class="text-sm font-semibold text-[#1A5C6B] group-hover:text-[#13434e] group-hover:underline transition-all">
                                                    @ngo.Ngo.Name
                                                </span>
                                                @if (ngo.Cause.HasValue)
                                                {
                                                    <span class="text-xs text-gray-500 mt-0.5 flex items-center">
                                                        <svg class="w-3.5 h-3.5 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                                        </svg>
                                                        @ngo.Cause.Value.Name
                                                    </span>
                                                }
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-page="/Programmes/Details" asp-route-id="@programme.ProgrammeId" class="group flex flex-col">
                                                <span class="text-sm font-semibold text-[#1A5C6B] group-hover:text-[#13434e] group-hover:underline transition-all">
                                                    @programme.ProgrammeName
                                                </span>
                                                <span class="text-xs text-gray-500 mt-0.5 flex items-center">
                                                    <svg class="w-3.5 h-3.5 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                                    </svg>
                                                    Programme
                                                </span>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <p class="text-sm text-gray-500">
                        Thank you for your generosity. Your contributions make a difference in the lives of those in need.
                    </p>
                </div>
            </div>

            <!-- Pagination -->
            @if (Model.Donations.TotalPages > 1)
            {
                <div class="mt-8 flex justify-center gap-2">
                    @if (Model.Donations.PageNumber > 1)
                    {
                        <button on:click="@(() => Model.PageChangedAsync(Model.Donations.PageNumber - 1))" class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-gray-700 font-semibold cursor-pointer">
                            Previous
                        </button>
                    }

                    @for (int i = 1; i <= Model.Donations.TotalPages; i++)
                    {
                        int pageIndex = i;

                        if (pageIndex == Model.Donations.PageNumber)
                        {
                            <span class="px-4 py-2 bg-[#1A5C6B] text-white rounded-lg font-semibold">@pageIndex</span>
                        }
                        else
                        {
                            <button on:click="@(() => Model.PageChangedAsync(pageIndex))" class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-gray-700 font-semibold cursor-pointer">
                                @pageIndex
                            </button>
                        }
                    }

                    @if (Model.Donations.PageNumber < Model.Donations.TotalPages)
                    {
                        <button on:click="@(() => Model.PageChangedAsync(Model.Donations.PageNumber + 1))" class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-gray-700 font-semibold cursor-pointer">
                            Next
                        </button>
                    }
                </div>
            }
        }
    </main>
</div>
