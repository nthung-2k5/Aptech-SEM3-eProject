@page
@model ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6">
    <div class="bg-white rounded-lg shadow p-6">
        <h1 class="text-2xl font-bold mb-6">My Profile</h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4"
                 role="alert">
                <span class="block sm:inline">@TempData["SuccessMessage"]</span>
            </div>
        }

        <form method="post">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Full Name</label>
                    <input asp-for="Input.FullName" bind
                           class="mt-1 input w-full"/>
                    <span asp-validation-for="Input.FullName" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Email Address (Read-only)</label>
                    <input asp-for="Input.Email" bind
                           class="mt-1 input w-full"
                           readonly/>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Phone Number (Read-only)</label>
                    <input asp-for="Input.PhoneNumber" bind
                           class="mt-1 input w-full"
                           readonly/>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Date of Birth</label>
                    <input asp-for="Input.DateOfBirth" bind type="date"
                           class="mt-1 input w-full"/>
                    <span asp-validation-for="Input.DateOfBirth" class="text-red-500 text-xs"></span>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700">Address</label>
                    <input asp-for="Input.Address" bind
                           class="mt-1 input w-full"/>
                    <span asp-validation-for="Input.Address" class="text-red-500 text-xs"></span>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700">Occupation</label>
                    <input asp-for="Input.Occupation" bind
                           class="mt-1 input w-full"/>
                    <span asp-validation-for="Input.Occupation" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div class="mt-6 w-full flex justify-end">
                <button type="submit" class="btn btn-secondary">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
