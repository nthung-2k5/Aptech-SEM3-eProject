@using GiveAID.Models
@model GalleryBoard

@{
    bool isAdmin = User.Identity?.IsAuthenticated == true && User.IsInRole(nameof(UserRole.Admin));
}

<div>
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div class="flex flex-wrap gap-2">
            <button type="button" on:click="@(() => Model.SetFilter("All"))"
                    class="px-4 py-2 rounded-full text-sm font-medium transition-colors @(Model.Filter == "All" ? "bg-[#1A5C6B] text-white" : "bg-white border border-[#E3DDD3] text-[#6B6459] hover:border-[#1A5C6B]")">
                All
            </button>
            @foreach (var cause in Model.Causes)
            {
                <button type="button" on:click="@(() => Model.SetFilter(cause.Name))"
                        class="px-4 py-2 rounded-full text-sm font-medium transition-colors @(Model.Filter == cause.Name ? "bg-[#1A5C6B] text-white" : "bg-white border border-[#E3DDD3] text-[#6B6459] hover:border-[#1A5C6B]")">
                    @cause.Name
                </button>
            }
        </div>

        @if (isAdmin)
        {
            <button type="button" on:click="@(() => Model.OpenCreateModal())"
                    class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A]">
                <i class="ph ph-plus"></i> Add Image
            </button>
        }
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        @foreach (var img in Model.FilteredImages)
        {
            bool hasProgramme = img.AssociatedProgramme.HasValue;
            var routeId = img.AssociatedProgramme?.Id;

            <a asp-page="@(hasProgramme ? "/Programmes/Details" : null)" asp-route-id="@routeId"
               class="group relative overflow-hidden rounded-xl bg-[#E3DDD3] aspect-[4/3] border border-[#E3DDD3]">
                <img src="@img.ImageUri"
                     alt="@img.Caption"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

                @if (isAdmin)
                {
                    <div x-data="{ confirmDelete() { Swal.fire({ title: 'Are you sure?', text: 'This action cannot be undone.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', cancelButtonColor: '#3085d6', confirmButtonText: 'Yes, delete it!' }).then((result) => { if (result.isConfirmed) { $refs.deleteBtn.click(); } }) } }"
                        class="absolute top-2 right-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity z-10">
                        <button type="button" on:click="@(() => Model.OpenEditModal(img.Id))"
                                class="btn btn-square text-blue-600">
                            <i class="ph ph-pencil"></i>
                        </button>
                        <button type="button" @@click.prevent="confirmDelete()"
                                class="btn btn-square text-red-500">
                            <i class="ph ph-trash"></i>
                        </button>
                        <button x-ref="deleteBtn" on:click="@(() => Model.Delete(img.Id))" style="display:none;"></button>
                    </div>
                }

                <div
                    class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                    @if (img.AssociatedProgramme.HasValue)
                    {
                        <span
                            class="text-xs text-[#E8C07D] font-semibold uppercase tracking-wide">@img.AssociatedProgramme.Value.Name</span>
                    }
                    <p class="text-sm text-white font-medium">@img.Caption</p>
                </div>
            </a>
        }
    </div>

    @if (isAdmin)
    {
        <dialog class="modal @(Model.IsModalOpen ? "modal-open" : "")">
            <div class="modal-box bg-white max-w-3xl w-full">
                <h3 class="font-bold text-lg mb-4 text-[#1C1A17]">@(Model.EditingId.HasValue ? "Edit Image" : "Add Gallery Image")</h3>
                <form on:submit="@(() => Model.Save())" enctype="multipart/form-data">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
                        <!-- Left Side: Inputs -->
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Caption</label>
                                <input type="text" asp-for="Form.Caption" bind required
                                       class="input w-full"/>
                                <span asp-validation-for="Form.Caption"></span>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Associated
                                    Programme</label>
                                <select asp-for="Form.AssociatedProgrammeId" bind
                                        class="select w-full">
                                    <option value="" disabled selected>-- Select Programme --</option>
                                    @foreach (var prog in Model.Programmes)
                                    {
                                        <option value="@prog.Id">@prog.Name (@prog.NgoName)</option>
                                    }
                                </select>
                                <span asp-validation-for="Form.AssociatedProgrammeId"></span>
                            </div>
                        </div>

                        <!-- Right Side: Image Upload and Preview -->
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Image File</label>
                                <input type="file" asp-for="ImageFile" bind accept="image/*"
                                       class="file-input w-full"/>
                                <span asp-validation-for="PreviewImageSource"></span>
                            </div>
                            <div
                                class="mt-4 border border-[#E3DDD3] rounded-xl overflow-hidden aspect-[4/3] bg-gray-50 flex items-center justify-center">
                                <img id="imgPreview" src="@(Model.PreviewImageSource ?? "")" alt="Image Preview"
                                     class="w-full h-full object-cover @(string.IsNullOrEmpty(Model.PreviewImageSource) ? "hidden" : "")"
                                     onload="this.classList.remove('hidden')"/>
                            </div>
                        </div>
                    </div>
                    <div class="modal-action">
                        <button type="button" on:click="@(() => Model.CloseModal())" class="btn">Close</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </dialog>

        <script>
            document.getElementById('imgPreview').addEventListener('error', function () {
                this.classList.remove('hidden');
            });
        </script>
    }
</div>