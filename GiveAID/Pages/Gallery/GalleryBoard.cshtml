@model GalleryBoard

<div>
    <div class="flex flex-wrap items-center justify-end gap-4 mb-8">
        <!-- Admin controls -->
        <button type="button" on:click="@(() => Model.OpenCreateModal())" class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A]">
            <i class="ph ph-plus"></i> Add Image
        </button>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        @foreach (var img in Model.Images.Where(i => Model.Filter == "All" || i.AssociatedProgrammeName == Model.Filter))
        {
            <div class="group relative overflow-hidden rounded-xl bg-[#E3DDD3] aspect-[4/3] border border-[#E3DDD3]">
                <img src="@img.ImageUri"
                     alt="@img.Caption"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                
                <div class="absolute top-2 right-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity z-10">
                    <button type="button" on:click="@(() => Model.OpenEditModal(img.Id))" class="btn btn-square text-blue-600">
                        <i class="ph ph-pencil"></i>
                    </button>
                    <button type="button" on:click="@(() => Model.Delete(img.Id))" class="btn btn-square text-red-500">
                        <i class="ph ph-trash"></i>
                    </button>
                </div>
                
                <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                    <span class="text-xs text-[#E8C07D] font-semibold uppercase tracking-wide">@img.AssociatedProgrammeName</span>
                    <p class="text-sm text-white font-medium">@img.Caption</p>
                </div>
            </div>
        }
    </div>

    <!-- DaisyUI Modal for Create/Update -->
    <dialog class="modal @(Model.IsModalOpen ? "modal-open" : "")">
        <div class="modal-box bg-white max-w-3xl w-full">
            <h3 class="font-bold text-lg mb-4 text-[#1C1A17]">@(Model.EditingId.HasValue ? "Edit Image" : "Add Gallery Image")</h3>
            <form on:submit="@(() => Model.Save())" enctype="multipart/form-data">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
                    <!-- Left Side: Inputs -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Caption</label>
                            <input type="text" asp-for="Form.Caption" required
                                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B] bg-white text-black" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Associated Programme</label>
                            <select asp-for="Form.AssociatedProgrammeId"
                                    class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B] bg-white text-black">
                                <option value="">-- Select Programme --</option>
                                @foreach (var prog in Model.Programmes)
                                {
                                    <option value="@prog.Id">@prog.Name (@prog.Ngo)</option>
                                }
                            </select>
                        </div>
                    </div>
                    
                    <!-- Right Side: Image Upload and Preview -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Image File</label>
                            <input type="file" asp-for="Form.ImageFile" accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])"
                                   class="file-input w-full" />
                        </div>
                        <div class="mt-4 border border-[#E3DDD3] rounded-xl overflow-hidden aspect-[4/3] bg-gray-50 flex items-center justify-center">
                            <img id="imgPreview" src="@(Model.PreviewImageUrl ?? "")" alt="Image Preview" 
                                 class="w-full h-full object-cover @(string.IsNullOrEmpty(Model.PreviewImageUrl) ? "hidden" : "")" 
                                 onload="this.classList.remove('hidden')" />
                        </div>
                    </div>
                </div>
                <div class="modal-action">
                    <button type="submit" class="btn btn-primary bg-[#1A5C6B] border-none text-white hover:bg-[#154D5A]">Save</button>
                    <button type="button" on:click="@(() => Model.CloseModal())" class="btn">Close</button>
                </div>
            </form>
        </div>
    </dialog>

    <script>
        document.getElementById('imgPreview').addEventListener('error', function() {
            this.classList.remove('hidden');
        });
    </script>
</div>