@page "{id:guid}"
@model DetailsModel
@{
    ViewData["Title"] = Model.Ngo?.Name ?? "NGO Details";
}

@if (Model.Ngo == null)
{
    <div class="flex flex-col items-center justify-center py-32 text-center">
        <div class="size-20 bg-[#E3DDD3] rounded-full flex items-center justify-center mb-6">
            <i class="ph ph-magnifying-glass text-3xl text-[#6B6459]"></i>
        </div>
        <h1 class="font-['Playfair_Display',serif] text-2xl font-bold text-[#1C1A17] mb-2">NGO Not Found</h1>
        <p class="text-[#6B6459] mb-6">This NGO partner may have been removed or doesn't exist.</p>
        <a asp-page="/Partners" class="flex items-center gap-2 px-6 py-3 bg-[#1A5C6B] text-white font-semibold rounded-xl hover:bg-[#154D5A] transition-colors no-underline">
            <i class="ph ph-arrow-left"></i> Back to Partners
        </a>
    </div>
}
else
{
    <!-- Hero Banner -->
    <div class="bg-gradient-to-br from-[#1A5C6B] to-[#4A8B7F] text-white py-14 px-6">
        <div class="max-w-7xl mx-auto">

            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div class="flex items-center gap-5">
                    <div class="size-16 md:size-20 bg-white/20 rounded-2xl flex items-center justify-center flex-shrink-0">
                        <i class="ph ph-buildings text-3xl md:text-4xl text-white"></i>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <span class="inline-flex items-center gap-1 text-xs font-semibold bg-[#4A8B7F]/50 border border-white/20 text-white px-3 py-1 rounded-full">
                                <i class="ph-fill ph-check-circle"></i> Verified NGO Partner
                            </span>
                        </div>
                        <h1 class="font-['Playfair_Display',serif] text-3xl md:text-4xl font-bold text-white leading-tight">
                            @Model.Ngo.Name
                        </h1>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
                {
                    <form method="post" asp-page-handler="ToggleFollow" asp-route-id="@Model.Ngo.Id" class="m-0 flex-shrink-0">
                        <button type="submit"
                                class="flex items-center gap-2 px-6 py-3 @(Model.IsFollowing ? "bg-white/20 border border-white/40 hover:bg-white/30" : "bg-[#C97C2E] hover:bg-[#B06B20]") text-white font-semibold rounded-xl transition-all">
                            <i class="ph-fill @(Model.IsFollowing ? "ph-check" : "ph-star") text-lg"></i>
                            @(Model.IsFollowing ? "Following" : "Follow NGO")
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Left: NGO Details -->
            <div class="lg:col-span-2 space-y-6">

                <!-- About Section -->
                <div class="bg-white border border-[#E3DDD3] rounded-2xl p-8">
                    <h2 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17] mb-4 flex items-center gap-2">
                        <i class="ph ph-info text-[#4A8B7F]"></i> About this Organisation
                    </h2>
                    <p class="text-[#6B6459] leading-relaxed whitespace-pre-line">@Model.Ngo.Description</p>
                </div>

                <!-- Contact Information -->
                @{
                    bool hasContact = !string.IsNullOrEmpty(Model.Ngo.Address)
                                   || !string.IsNullOrEmpty(Model.Ngo.PhoneNumber)
                                   || !string.IsNullOrEmpty(Model.Ngo.Website);
                }
                @if (hasContact)
                {
                    <div class="bg-white border border-[#E3DDD3] rounded-2xl p-8">
                        <h2 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17] mb-6 flex items-center gap-2">
                            <i class="ph ph-address-book text-[#4A8B7F]"></i> Contact Information
                        </h2>
                        <ul class="space-y-4">
                            @if (!string.IsNullOrEmpty(Model.Ngo.Address))
                            {
                                <li class="flex items-start gap-4 p-4 bg-[#F6F1E9] rounded-xl">
                                    <div class="size-9 bg-[#E8F4F1] rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                                        <i class="ph ph-map-pin text-[#4A8B7F] text-lg"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-[#6B6459] font-semibold uppercase tracking-wide mb-0.5">Address</p>
                                        <p class="text-[#1C1A17] font-medium">@Model.Ngo.Address</p>
                                    </div>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(Model.Ngo.PhoneNumber))
                            {
                                <li class="flex items-start gap-4 p-4 bg-[#F6F1E9] rounded-xl">
                                    <div class="size-9 bg-[#E8F4F1] rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="ph ph-phone text-[#4A8B7F] text-lg"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-[#6B6459] font-semibold uppercase tracking-wide mb-0.5">Phone</p>
                                        <a href="tel:@Model.Ngo.PhoneNumber" class="text-[#1A5C6B] font-medium hover:underline no-underline">@Model.Ngo.PhoneNumber</a>
                                    </div>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(Model.Ngo.Website))
                            {
                                <li class="flex items-start gap-4 p-4 bg-[#F6F1E9] rounded-xl">
                                    <div class="size-9 bg-[#E8F4F1] rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="ph ph-globe text-[#4A8B7F] text-lg"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-[#6B6459] font-semibold uppercase tracking-wide mb-0.5">Website</p>
                                        <a href="@Model.Ngo.Website" target="_blank" rel="noopener noreferrer"
                                           class="text-[#1A5C6B] font-medium hover:underline break-all">@Model.Ngo.Website</a>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <!-- Corporate Partners -->
                @if (Model.Ngo.Partners.Length > 0)
                {
                    <div class="bg-white border border-[#E3DDD3] rounded-2xl p-8">
                        <h2 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17] mb-6 flex items-center gap-2">
                            <i class="ph ph-handshake text-[#C97C2E]"></i> Corporate Partners
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            @foreach (var partner in Model.Ngo.Partners)
                            {
                                <div class="flex items-center gap-4 p-4 bg-[#F6F1E9] rounded-xl border border-[#E3DDD3] hover:border-[#C97C2E] transition-colors">
                                    <!-- Logo or initials fallback -->
                                    @if (!string.IsNullOrEmpty(partner.LogoUrl))
                                    {
                                        <img src="@partner.LogoUrl" alt="@partner.Name logo"
                                             class="size-12 rounded-lg object-contain bg-white border border-[#E3DDD3] flex-shrink-0"/>
                                    }
                                    else
                                    {
                                        <div class="size-12 bg-[#1A5C6B] rounded-lg flex items-center justify-center flex-shrink-0">
                                            <span class="font-['Playfair_Display',serif] text-white font-bold text-lg">
                                                @(partner.Name.Length > 0 ? partner.Name[0].ToString().ToUpper() : "?")
                                            </span>
                                        </div>
                                    }
                                    <div class="min-w-0">
                                        <p class="font-semibold text-[#1C1A17] text-sm truncate">@partner.Name</p>
                                        @if (!string.IsNullOrEmpty(partner.WebsiteLink))
                                        {
                                            <a href="@partner.WebsiteLink" target="_blank" rel="noopener noreferrer"
                                               class="text-xs text-[#1A5C6B] hover:underline truncate block">Visit website</a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Back link -->
                <div>
                    <a asp-page="/Partners" class="inline-flex items-center gap-2 text-sm text-[#6B6459] hover:text-[#1A5C6B] font-medium transition-colors no-underline">
                        <i class="ph ph-arrow-left"></i> Back to all NGO Partners
                    </a>
                </div>
            </div>

            <!-- Right: Donation Sidebar -->
            <div class="lg:col-span-1">
                <div class="bg-white border border-[#E3DDD3] rounded-2xl overflow-hidden sticky top-24">
                    <!-- Sidebar header -->
                    <div class="bg-gradient-to-r from-[#C97C2E] to-[#E8A84A] px-6 py-5">
                        <h2 class="font-['Playfair_Display',serif] text-xl font-bold text-white mb-1">Support This NGO</h2>
                        <p class="text-white/80 text-sm">Your contribution makes a real difference.</p>
                    </div>

                    <div class="p-6">
                        <p class="text-sm text-[#6B6459] mb-6 leading-relaxed">
                            Help <strong class="text-[#1C1A17]">@Model.Ngo.Name</strong> continue their mission by making a direct donation today.
                        </p>
                        
                        <a asp-page="/Donate/Index" asp-route-ngoId="@Model.Ngo.Id"
                           class="w-full flex items-center justify-center gap-2 py-4 bg-[#C97C2E] hover:bg-[#B06B20] text-white font-bold rounded-xl transition-colors text-base">
                            <i class="ph-fill ph-hand-heart text-xl"></i> Donate Now
                        </a>
                        
                        <!-- Stats row -->
                        <div class="mt-6 pt-5 border-t border-[#E3DDD3] grid grid-cols-2 gap-4 text-center">
                            <div>
                                <div class="font-['Playfair_Display',serif] text-xl font-bold text-[#1A5C6B]">100%</div>
                                <div class="text-xs text-[#6B6459]">Funds Tracked</div>
                            </div>
                            <div>
                                <div class="font-['Playfair_Display',serif] text-xl font-bold text-[#1A5C6B]">Verified</div>
                                <div class="text-xs text-[#6B6459]">NGO Status</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
}
