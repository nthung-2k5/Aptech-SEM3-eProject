@page "{id:guid}"
@model DetailsModel
@{
    ViewData["Title"] = Model.Ngo?.Name ?? "NGO Details";
}

<div class="container mx-auto p-4 py-10">
    @if (Model.Ngo != null)
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- NGO Details Section -->
            <div class="lg:col-span-2 space-y-6">
                <div class="card bg-base-100 shadow-xl border border-base-200">
                    <div class="card-body">
                        <div class="flex justify-between items-start mb-4">
                            <h1 class="card-title text-4xl font-bold">@Model.Ngo.Name</h1>

                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
                            {
                                <form method="post" asp-page-handler="ToggleFollow" asp-route-id="@Model.Ngo.Id"
                                      class="m-0">
                                    <button type="submit"
                                            class="btn @(Model.IsFollowing ? "btn-outline btn-primary" : "btn-primary") rounded-full gap-2 px-6">
                                        <i class="ph-fill @(Model.IsFollowing ? "ph-check" : "ph-star") text-lg"></i>
                                        @(Model.IsFollowing ? "Following" : "Follow")
                                    </button>
                                </form>
                            }
                        </div>
                        <p class="text-lg opacity-80 whitespace-pre-line mb-6">@Model.Ngo.Description</p>

                        <div class="divider">Contact Information</div>
                        <ul class="space-y-3">
                            @if (!string.IsNullOrEmpty(Model.Ngo.Address))
                            {
                                <li class="flex items-start">
                                    <svg class="w-6 h-6 mr-3 text-primary shrink-0" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.242-4.243a8 8 0 1111.314 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                    <span>@Model.Ngo.Address</span>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(Model.Ngo.PhoneNumber))
                            {
                                <li class="flex items-center">
                                    <svg class="w-6 h-6 mr-3 text-primary shrink-0" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                    </svg>
                                    <span>@Model.Ngo.PhoneNumber</span>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(Model.Ngo.Website))
                            {
                                <li class="flex items-center">
                                    <svg class="w-6 h-6 mr-3 text-primary shrink-0" fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                                    </svg>
                                    <a href="@Model.Ngo.Website" target="_blank"
                                       class="link link-primary">@Model.Ngo.Website</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Donation Section -->
            <div class="lg:col-span-1">
                <div class="card bg-base-100 shadow-xl border border-base-200 sticky top-24">
                    <div class="card-body">
                        <h2 class="card-title text-2xl font-bold mb-4">Make a Donation</h2>
                        <p class="text-sm opacity-80 mb-6">Support @Model.Ngo.Name by making a direct contribution.</p>

                        <form method="post" asp-page-handler="Donate" asp-route-id="@Model.Ngo.Id">
                            <div class="form-control w-full mb-6">
                                <label class="label">
                                    <span class="label-text font-semibold">Select a Cause (Optional)</span>
                                </label>
                                <select asp-for="SelectedCauseId" bind class="select select-bordered w-full">
                                    <option value="">-- General Donation --</option>
                                    @foreach (var cause in Model.Causes)
                                    {
                                        <option value="@cause.Id">@cause.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="SelectedCauseId"></span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-full">Donate Now</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
