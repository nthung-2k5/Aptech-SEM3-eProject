@page
@model NgoModel
@{
    ViewData["Title"] = "NGOs";
}

<div>
    <hero-component title="Our NGO Partners" subtitle="Verified organisations making a difference worldwide"/>

    <div class="max-w-7xl mx-auto px-6 py-14">

        @if (Model.Ngos.Length == 0)
        {
            <!-- Empty state -->
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <div class="size-20 bg-[#E3DDD3] rounded-full flex items-center justify-center mb-6">
                    <i class="ph ph-globe text-3xl text-[#6B6459]"></i>
                </div>
                <h2 class="font-['Playfair_Display',serif] text-2xl font-bold text-[#1C1A17] mb-2">No NGO Partners Yet</h2>
                <p class="text-[#6B6459] max-w-sm">Our NGO network is growing. Check back soon to meet our verified partner organisations.</p>
            </div>
        }
        else
        {
            <!-- Section header -->
            <div class="mb-10">
                <p class="text-[#C97C2E] font-semibold text-sm uppercase tracking-widest mb-2">Our Network</p>
                <div class="flex items-end justify-between">
                    <h2 class="font-['Playfair_Display',serif] text-3xl md:text-4xl font-bold text-[#1C1A17] flex items-center gap-3">
                        <i class="ph ph-globe text-[#4A8B7F]"></i> NGO Network
                    </h2>
                    <span class="text-sm text-[#6B6459] hidden md:block">@Model.Ngos.Length partner@(Model.Ngos.Length != 1 ? "s" : "") verified</span>
                </div>
                <div class="mt-4 h-0.5 w-16 bg-[#C97C2E] rounded-full"></div>
            </div>

            <!-- NGO Cards Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var ngo in Model.Ngos)
                {
                    <a asp-page="/Ngo/Details" asp-route-id="@ngo.Id"
                       class="group bg-white border border-[#E3DDD3] rounded-2xl p-6 hover:border-[#4A8B7F] hover:shadow-lg transition-all duration-200 flex flex-col no-underline">

                        <!-- Icon + Name -->
                        <div class="flex items-start gap-4 mb-4">
                            <div class="size-12 bg-[#E8F4F1] rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#4A8B7F] transition-colors duration-200">
                                <i class="ph ph-buildings text-[#4A8B7F] text-xl group-hover:text-white transition-colors duration-200"></i>
                            </div>
                            <div class="min-w-0">
                                <h3 class="font-['Playfair_Display',serif] text-lg font-bold text-[#1C1A17] group-hover:text-[#4A8B7F] transition-colors duration-200 leading-tight">
                                    @ngo.Name
                                </h3>
                                <span class="inline-flex items-center gap-1 text-xs text-[#4A8B7F] font-semibold bg-[#E8F4F1] px-2 py-0.5 rounded-full mt-1">
                                    <i class="ph-fill ph-check-circle"></i> Verified Partner
                                </span>
                            </div>
                        </div>

                        <!-- Description -->
                        <p class="text-sm text-[#6B6459] leading-relaxed line-clamp-3 flex-grow">
                            @ngo.Description
                        </p>

                        <!-- Footer -->
                        <div class="mt-5 pt-4 border-t border-[#E3DDD3] flex items-center justify-between">
                            <span class="text-xs text-[#6B6459]">View details</span>
                            <span class="size-7 rounded-full bg-[#F6F1E9] group-hover:bg-[#4A8B7F] flex items-center justify-center transition-colors duration-200">
                                <i class="ph ph-arrow-right text-sm text-[#6B6459] group-hover:text-white transition-colors duration-200"></i>
                            </span>
                        </div>
                    </a>
                }
            </div>

            <!-- CTA Banner -->
            <div class="mt-16 bg-gradient-to-r from-[#1A5C6B] to-[#4A8B7F] rounded-2xl px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
                <div>
                    <h3 class="font-['Playfair_Display',serif] text-2xl font-bold text-white mb-2">Want to partner with us?</h3>
                    <p class="text-white/70 text-sm">Join our growing network of verified NGOs and reach more people who need your support.</p>
                </div>
                <a asp-page="/Contact"
                   class="flex-shrink-0 flex items-center gap-2 px-7 py-3 bg-[#C97C2E] hover:bg-[#B06B20] text-white font-semibold rounded-xl transition-all hover:gap-3 no-underline">
                    Get in Touch <i class="ph ph-arrow-right"></i>
                </a>
            </div>
        }
    </div>
</div>
