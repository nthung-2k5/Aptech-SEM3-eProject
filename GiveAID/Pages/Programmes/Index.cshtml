@page "/Prorgammes"
@model ProgrammesModel
@{
    ViewData["Title"] = "Our Programmes";
}

<div class="min-h-screen bg-[#F6F1E9] pb-12">
    <!-- Header -->
    <div class="bg-[#1A5C6B] text-white py-12 mb-8">
        <div class="max-w-7xl mx-auto px-6">
            <h1 class="font-['Playfair_Display',serif] text-4xl font-bold">Our Programmes</h1>
            <p class="font-['Source_Sans_3',sans-serif] text-white/80 mt-2">Discover and support causes that matter to you.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Sidebar (Left) -->
            <aside class="w-full lg:w-1/4">
                <form method="get" class="bg-white p-6 rounded-xl shadow-sm border border-[#E3DDD3] space-y-6">
                    <div>
                        <label class="block font-semibold mb-2 text-[#1C1A17]">Search</label>
                        <div class="relative">
                            <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="text" asp-for="Query.SearchTerm" class="w-full pl-10 pr-3 py-2 border rounded-lg focus:ring-2 focus:ring-[#1A5C6B] focus:border-[#1A5C6B] outline-none" placeholder="Search programmes...">
                        </div>
                    </div>
                    <div>
                        <label class="block font-semibold mb-2 text-[#1C1A17]">Filter by Cause</label>
                        <select asp-for="Query.Cause" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-[#1A5C6B] outline-none">
                            <option value="">All Causes</option>
                            <option value="Education">Education</option>
                            <option value="Health">Health</option>
                            <option value="Hunger">Hunger</option>
                            <option value="Inclusion">Inclusion</option>
                            <option value="Emergency">Emergency</option>
                        </select>
                    </div>
                    <div>
                        <label class="block font-semibold mb-2 text-[#1C1A17]">Filter by NGO</label>
                        <select asp-for="Query.Ngo" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-[#1A5C6B] outline-none">
                            <option value="">All NGOs</option>
                            <option value="EduCare Foundation">EduCare Foundation</option>
                            <option value="Water Aid">Water Aid</option>
                            <option value="Food Bank">Food Bank</option>
                            <option value="Global Women">Global Women</option>
                            <option value="Red Cross">Red Cross</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full py-2 bg-[#1A5C6B] text-white rounded-lg hover:bg-[#154D5A] transition-colors font-semibold">Apply Filters</button>
                    <a asp-page="/Programmes/Index" class="block text-center mt-2 text-sm text-gray-500 hover:text-gray-800">Clear Filters</a>
                </form>
            </aside>

            <!-- Main Content (Right) -->
            <div class="w-full lg:w-3/4 flex flex-col">
                <!-- Top Bar -->
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold font-['Playfair_Display',serif] text-[#1C1A17]">
                        @if(Model.TotalCount > 0)
                        {
                            <text>Found @Model.TotalCount Programmes</text>
                        }
                        else
                        {
                            <text>No programmes found.</text>
                        }
                    </h2>
                </div>

                <!-- Cards Grid -->
                <div class="grid md:grid-cols-2 gap-6 flex-grow">
                    @foreach (var p in Model.Programmes)
                    {
                        var timeRemaining = p.EndDate - DateTime.Now;
                        bool isStarted = p.StartDate <= DateTime.Now;
                        string timeText = isStarted ? timeRemaining.TotalDays > 0 ? $"{(int)timeRemaining.TotalDays} days left" : "Ended" : $"Starts in {(p.StartDate - DateTime.Now).Days} days";
                        int progress = p.TargetAmount is > 0 ? (int)(p.RaisedAmount / p.TargetAmount.Value * 100) : 0;
                        if(progress > 100) progress = 100;

                        <a asp-page="/Programmes/Details" asp-route-id="@p.Id" class="block bg-white border border-[#E3DDD3] rounded-xl overflow-hidden hover:shadow-lg transition-all group no-underline text-inherit flex flex-col">
                            <div class="h-48 overflow-hidden relative">
                                <img src="@p.ImageUrl" alt="@p.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                <div class="absolute top-3 left-3 bg-[#1A5C6B] text-white text-xs px-3 py-1 rounded-full font-semibold shadow-md">
                                    @p.Cause
                                </div>
                            </div>
                            <div class="p-5 flex-grow flex flex-col">
                                <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17] mb-2 group-hover:text-[#C97C2E] transition-colors">@p.Name</h3>
                                <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
                                    <i class="ph ph-buildings"></i>
                                    <span>@p.Ngo</span>
                                </div>
                                <div class="mt-auto">
                                    <div class="flex justify-between text-sm mb-2 text-gray-600 font-medium">
                                        <span>$@p.RaisedAmount.ToString("N0") raised</span>
                                        @if(p.TargetAmount.HasValue)
                                        {
                                            <span>of $@p.TargetAmount.Value.ToString("N0")</span>
                                        }
                                    </div>
                                    @if(p.TargetAmount.HasValue)
                                    {
                                        <div class="w-full bg-gray-200 rounded-full h-2 mb-4 overflow-hidden">
                                            <div class="bg-[#C97C2E] h-2 rounded-full" style="width: @progress%"></div>
                                        </div>
                                    }
                                    
                                    <div class="flex items-center justify-between pt-4 border-t border-gray-100 text-sm">
                                        <div class="flex items-center gap-1 text-gray-500">
                                            <i class="ph ph-users"></i>
                                            <span>@p.DonationCount</span>
                                        </div>
                                        <div class="flex items-center gap-1 text-[#1A5C6B] font-semibold bg-blue-50 px-3 py-1 rounded-full">
                                            <i class="ph ph-clock"></i>
                                            <span>@timeText</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="mt-10 flex justify-center gap-2">
                        @if (Model.Query.PageNumber > 1)
                        {
                            <a asp-route-PageNumber="@(Model.Query.PageNumber - 1)"
                               asp-route-SearchTerm="@Model.Query.SearchTerm"
                               asp-route-Cause="@Model.Query.Cause"
                               asp-route-Ngo="@Model.Query.Ngo"
                               class="px-4 py-2 bg-white border border-[#E3DDD3] rounded-lg hover:bg-gray-50 transition-colors no-underline text-[#1C1A17]">Previous</a>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.Query.PageNumber)
                            {
                                <span class="px-4 py-2 bg-[#1A5C6B] text-white rounded-lg">@i</span>
                            }
                            else
                            {
                                <a asp-route-PageNumber="@i"
                                   asp-route-SearchTerm="@Model.Query.SearchTerm"
                                   asp-route-Cause="@Model.Query.Cause"
                                   asp-route-Ngo="@Model.Query.Ngo"
                                   class="px-4 py-2 bg-white border border-[#E3DDD3] rounded-lg hover:bg-gray-50 transition-colors no-underline text-[#1C1A17]">@i</a>
                            }
                        }

                        @if (Model.Query.PageNumber < Model.TotalPages)
                        {
                            <a asp-route-PageNumber="@(Model.Query.PageNumber + 1)"
                               asp-route-SearchTerm="@Model.Query.SearchTerm"
                               asp-route-Cause="@Model.Query.Cause"
                               asp-route-Ngo="@Model.Query.Ngo"
                               class="px-4 py-2 bg-white border border-[#E3DDD3] rounded-lg hover:bg-gray-50 transition-colors no-underline text-[#1C1A17]">Next</a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
