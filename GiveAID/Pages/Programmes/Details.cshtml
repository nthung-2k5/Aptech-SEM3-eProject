@page "/Programmes/{id:guid}"
@using GiveAID.Models
@model ProgrammeDetailsModel
@{
    ViewData["Title"] = Model.Programme?.Name ?? "Programme Details";
}

@if (Model.Programme != null)
{
    var p = Model.Programme;

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast toast-top toast-end z-50 mt-16">
            <div class="alert alert-success text-white">
                <span>@TempData["SuccessMessage"]</span>
            </div>
        </div>
        <script>
            setTimeout(() => {
                var t = document.querySelector('.toast');
                if (t) t.remove();
            }, 3000);
        </script>
    }

    var timeRemaining = p.EndDate - DateTimeOffset.Now;
    bool isStarted = p.StartDate <= DateTimeOffset.Now;
    string? timeText = null;

    if (!isStarted) { timeText = $"Starts in {(p.StartDate - DateTimeOffset.Now).Days} days"; }
    else if (timeRemaining.HasValue) { timeText = timeRemaining.Value.TotalDays > 0 ? $"{timeRemaining.Value.Days} days left" : "Ended"; }

    int progress = p.TargetAmount is > 0 ? (int)(p.RaisedAmount / p.TargetAmount.Value * 100) : 0;
    if (progress > 100) progress = 100;

    <div class="pb-12">
        <!-- Hero Section -->
        <div class="h-[40vh] min-h-[300px] max-h-[500px] relative">
            <img src="@(string.IsNullOrWhiteSpace(p.ImageUrl) ? "/images/programme-placeholder.png" : p.ImageUrl)"
                 onerror="this.onerror=null;this.src='/images/programme-placeholder.png'"
                 alt="@p.Name" class="w-full h-full object-cover"/>
            <div class="absolute inset-0 bg-black/50"></div>
            
            <div class="absolute top-6 left-6 md:left-12 z-10">
                <a asp-page="/Programmes/Index" class="btn btn-sm bg-white/20 hover:bg-white/40 border-none text-white backdrop-blur-md rounded-full shadow-lg pr-4">
                    <i class="ph ph-arrow-left"></i> Back to Programmes
                </a>
            </div>

            <div class="absolute inset-0 flex items-center">
                <div class="max-w-7xl mx-auto px-6 w-full text-white mt-16">
                    <div class="badge badge-secondary badge-xl uppercase tracking-widest font-bold mb-4">
                        @p.Cause
                    </div>
                    <h1 class="font-['Playfair_Display',serif] text-4xl md:text-5xl lg:text-6xl font-bold mb-4">@p.Name</h1>
                    <div class="flex flex-wrap items-center gap-6 text-white/90">
                        <div class="flex items-center gap-2">
                            <i class="ph ph-buildings text-xl"></i>
                            <span class="text-lg">@p.NgoName</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="ph ph-calendar-blank text-xl"></i>
                            <span class="text-lg">
                                @p.StartDate.ToString("MMM dd, yyyy") @(p.EndDate.HasValue ? $"- {p.EndDate.Value.ToString("MMM dd, yyyy")}" : "(Ongoing)")
                            </span>
                        </div>
                        @if (timeText != null)
                        {
                            <div class="flex items-center gap-2 font-semibold bg-white/20 px-3 py-1 rounded-full">
                                <i class="ph ph-clock text-xl"></i>
                                <span>@timeText</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 mt-10">
            <div class="grid lg:grid-cols-3 gap-10">
                <!-- Main Details -->
                <div class="lg:col-span-2 space-y-10">
                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#E3DDD3]">
                        <h2 class="text-2xl font-bold font-['Playfair_Display',serif] mb-6">About the Programme</h2>
                        <div class="prose max-w-none text-gray-700 leading-relaxed">
                            <p>@p.Description</p>
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#E3DDD3]">
                        <h2 class="text-2xl font-bold font-['Playfair_Display',serif] mb-6">About the Organizer</h2>
                        <a asp-page="/Ngo/Details" asp-route-id="@p.NgoId" asp-page-info class="flex items-start gap-4">
                            <div class="size-16 bg-[#1A5C6B]/10 rounded-full flex items-center justify-center shrink-0">
                                <i class="ph ph-bank text-3xl text-[#1A5C6B]"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold mb-2">@p.NgoName</h3>
                                <p class="text-gray-600 leading-relaxed">@p.NgoDescription</p>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Sidebar (Donation Info) -->
                <div>
                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#E3DDD3] sticky top-24">
                        <div class="mb-8">
                            <div class="flex justify-between items-end mb-2">
                                <span
                                    class="text-3xl font-bold text-[#1A5C6B] font-['Playfair_Display',serif]">@p.RaisedAmount.ToUsCurrencyString()</span>
                                @if (p.TargetAmount.HasValue)
                                {
                                    <span
                                        class="text-gray-500 mb-1">raised of @p.TargetAmount.Value.ToUsCurrencyString()</span>
                                }
                            </div>

                            @if (p.TargetAmount.HasValue)
                            {
                                <div class="w-full bg-gray-100 rounded-full h-3 mb-4 overflow-hidden">
                                    <div class="bg-[#C97C2E] h-3 rounded-full transition-all duration-1000"
                                         style="width: @progress%"></div>
                                </div>
                            }

                            <div class="flex justify-between text-gray-600 font-medium">
                                <div class="flex items-center gap-2">
                                    <i class="ph ph-users text-xl text-[#1A5C6B]"></i>
                                    <span>@p.DonationCount donations</span>
                                </div>
                                <div class="font-bold text-[#1A5C6B]">
                                    @progress%
                                </div>
                            </div>
                        </div>

                        @{
                            bool isEnded = p.EndDate.HasValue && p.EndDate.Value <= DateTimeOffset.Now;
                            bool isQuotaReached = p.TargetAmount.HasValue && p.RaisedAmount >= p.TargetAmount.Value;
                        }

                        @if (User.IsInRole(nameof(UserRole.Admin)))
                        {
                            <a asp-page="/Admin/Programme/Editor" asp-route-id="@p.Id" class="btn bg-[#1A5C6B] hover:bg-[#154D5A] text-white btn-block btn-xl border-none">
                                <i class="ph ph-pencil-simple text-xl"></i> Edit Programme
                            </a>
                        }
                        else
                        {
                            @if (isEnded)
                            {
                                <button class="btn btn-secondary btn-block btn-xl" disabled>
                                    The programme has ended. Thank you for your support!
                                </button>
                            }
                            else if (isQuotaReached)
                            {
                                <button class="btn btn-secondary btn-block btn-xl" disabled>
                                    The donation target has been reached. Thank you for your support!
                                </button>
                            }
                            else
                            {
                                <a asp-page="/Donate/Index" asp-route-programmeId="@p.Id" class="btn btn-secondary btn-block btn-xl">
                                    Donate Now
                                </a>
                            }
                            
                            <button class="btn btn-outline btn-block mt-4" onclick="inviteModal.showModal()">
                                <i class="ph ph-envelope-simple text-xl"></i>
                                Invite Friends
                            </button>
                        }

                        <div class="text-center text-sm text-gray-500 mt-6 flex items-center justify-center gap-2">
                            <i class="ph ph-shield-check text-[#1A5C6B] text-lg"></i>
                            <span>Secure & Verified Donation</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <dialog id="inviteModal" class="modal">
        <div class="modal-box">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
            </form>
            <h3 class="font-bold text-2xl mb-6 font-['Playfair_Display',serif]">Invite a Friend</h3>
            
            <form method="post" asp-page-handler="Invite">
                <div class="form-control w-full mb-4">
                    <label class="label"><span class="label-text font-bold">Friend's Email</span></label>
                    <input type="email" asp-for="InviteForm.FriendEmail" class="input input-bordered w-full" placeholder="friend@example.com" required />
                    <span asp-validation-for="InviteForm.FriendEmail" class="text-error text-sm mt-1"></span>
                </div>
                
                <div class="form-control w-full mb-4">
                    <label class="label"><span class="label-text font-bold">Subject</span></label>
                    <input type="text" asp-for="InviteForm.Subject" class="input input-bordered w-full" required />
                    <span asp-validation-for="InviteForm.Subject" class="text-error text-sm mt-1"></span>
                </div>
                
                <div class="form-control w-full mb-6">
                    <label class="label"><span class="label-text font-bold">Message</span></label>
                    <textarea asp-for="InviteForm.Body" class="textarea textarea-bordered h-48 w-full" required></textarea>
                    <span asp-validation-for="InviteForm.Body" class="text-error text-sm mt-1"></span>
                </div>
                
                <button type="submit" class="btn btn-secondary w-full">Send Invitation</button>
            </form>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>close</button>
        </form>
    </dialog>

    @if (!ModelState.IsValid)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                document.getElementById('inviteModal').showModal();
            });
        </script>
    }
}
