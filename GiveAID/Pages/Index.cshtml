@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="min-h-screen">
    <!-- Hero -->
    <hydro name="HeroSlider" />

    <!-- Causes section -->
    <section class="bg-[#F6F1E9] py-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-12 items-end mb-14">
                <div>
                    <p class="text-[#C97C2E] font-semibold text-sm uppercase tracking-widest mb-3">What We Support</p>
                    <h2 class="font-['Playfair_Display',serif] text-4xl md:text-5xl font-bold text-[#1C1A17] leading-tight">
                        Causes That<br/><span class="italic text-[#1A5C6B]">Matter</span></h2>
                </div>
                <p class="text-[#6B6459] leading-relaxed">
                    Donations are directed to specific causes managed by verified NGO partners. Choose what moves you
                    most — every contribution is tracked transparently.
                </p>
            </div>
            @{
                var themes = new[] 
                {
                    "bg-[#E8F3F5] text-[#1A5C6B] hover:bg-[#1A5C6B] hover:text-white", // Teal
                    "bg-[#FDF3E7] text-[#C97C2E] hover:bg-[#C97C2E] hover:text-white", // Amber
                    "bg-[#F2EDF7] text-[#6B4D91] hover:bg-[#6B4D91] hover:text-white", // Purple
                    "bg-[#FCEAE9] text-[#B84245] hover:bg-[#B84245] hover:text-white", // Rose
                    "bg-[#EBF5EE] text-[#2E7D4C] hover:bg-[#2E7D4C] hover:text-white"  // Green
                };
            }
            <div class="relative w-full">
                <div class="flex flex-row overflow-x-auto gap-4 pb-4 scrollbar-none snap-x [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
                    @for (int i = 0; i < Model.Causes.Length; i++)
                    {
                        var cause = Model.Causes[i];
                        var theme = themes[i % themes.Length];
                        <a href="/Programmes" onclick="localStorage.setItem('activeCause', '@cause.Id')"
                           class="btn border-none @theme rounded-full px-8 h-12 font-bold transition-all duration-300 snap-align-start shrink-0 no-underline shadow-sm hover:shadow-md hover:-translate-y-0.5">
                            @cause.Name
                        </a>
                    }
                </div>
                <!-- Fading Mask for Scroll Indication -->
                <div class="absolute right-0 top-0 bottom-4 w-24 bg-gradient-to-l from-[#F6F1E9] to-transparent pointer-events-none"></div>
            </div>
            
            <!-- Desktop Scroll Hint -->
            <div class="hidden md:flex justify-end items-center gap-1.5 mt-2 text-xs text-[#6B6459] opacity-70">
                <i class="ph ph-mouse-scroll"></i>
                <span>Use <kbd class="kbd kbd-xs bg-[#E3DDD3] border-none text-[#6B6459]">Shift</kbd> + Scroll to navigate</span>
            </div>
        </div>
    </section>

    <!-- Active Programmes Component -->
    <hydro name="ActiveProgrammes" />

    <!-- About strip -->
    <section class="bg-[#1C1A17] py-20">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=700&h=500&fit=crop&auto=format"
                     alt="Volunteers working" class="rounded-xl w-full object-cover h-80 opacity-90"/>
                <div class="absolute -bottom-6 -right-6 bg-[#C97C2E] text-white p-5 rounded-xl shadow-xl">
                    <div class="font-['Playfair_Display',serif] text-3xl font-bold">1+</div>
                    <div class="text-xs uppercase tracking-wide opacity-90">Month of Service</div>
                </div>
            </div>
            <div>
                <p class="text-[#C97C2E] text-sm font-semibold uppercase tracking-widest mb-3">About Give-AID</p>
                <h2 class="font-['Playfair_Display',serif] text-4xl font-bold text-white leading-tight mb-6">Established
                    by Major Companies, Driven by <span class="italic text-[#E8C07D]">Compassion</span></h2>
                <p class="text-white/60 leading-relaxed mb-6">
                    Give-AID was founded with contributions from leading corporations who believed that profit must
                    coexist with purpose. We coordinate welfare activities across India and beyond, bringing structured
                    funding to those who need it most.
                </p>
                <a asp-page="/AboutUs/Index"
                   class="flex items-center gap-2 text-[#E8C07D] font-semibold hover:gap-3 transition-all no-underline">
                    Read our story <i class="ph ph-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Partner Carousel Component -->
    <hydro name="PartnerCarousel" />

    <!-- CTA -->
    <section class="bg-[#C97C2E] py-20">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="font-['Playfair_Display',serif] text-4xl md:text-5xl font-bold text-white mb-4">Join the
                Movement</h2>
            <p class="text-white/80 text-lg mb-8">Register today to donate, invite friends, and stay connected with
                every programme we run.</p>
            <div class="flex flex-wrap justify-center gap-4">
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <a asp-page="/Register/Index"
                       class="px-8 py-4 bg-white text-[#C97C2E] font-bold rounded hover:bg-[#F6F1E9] transition-colors no-underline">
                        Create an Account
                    </a>
                }
                <a asp-page="/Programmes/Index"
                   class="px-8 py-4 bg-transparent border-2 border-white text-white font-bold rounded hover:bg-white/10 transition-colors no-underline">
                    Donate Directly
                </a>
            </div>
        </div>
    </section>
</div>