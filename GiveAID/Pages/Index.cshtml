@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="min-h-screen">
    <!-- Hero -->
    <section class="relative min-h-[92vh] flex items-center overflow-hidden bg-[#1A5C6B]">
        <div class="absolute inset-0">
            <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1600&h=900&fit=crop&auto=format" alt="Children receiving aid" class="w-full h-full object-cover opacity-20" />
            <div class="absolute inset-0 bg-gradient-to-r from-[#1A5C6B]/90 via-[#1A5C6B]/70 to-transparent"></div>
        </div>
        <div class="relative max-w-7xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-12 items-center">
            <div>
                <div class="inline-flex items-center gap-2 bg-[#C97C2E]/20 border border-[#C97C2E]/40 text-[#E8C07D] text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
                    <i class="ph-fill ph-heart text-current"></i> Non-Governmental Organisation
                </div>
                <h1 class="font-['Playfair_Display',serif] text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
                    Together We<br /><span class="text-[#E8C07D] italic">Give. Aid.</span><br />Transform.
                </h1>
                <p class="text-lg text-white/70 leading-relaxed mb-8 max-w-lg">
                    Give-AID unites NGOs, donors, and communities to fund welfare programmes for children, women, the elderly, and the differently-abled.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a asp-page="/Donate/Index" class="flex items-center gap-2 px-8 py-4 bg-[#C97C2E] hover:bg-[#B06B20] text-white font-semibold rounded transition-all hover:gap-3 no-underline">
                        Donate Now <i class="ph ph-arrow-right"></i>
                    </a>
                    <a asp-page="/Programs" class="flex items-center gap-2 px-8 py-4 border border-white/30 hover:border-white text-white font-semibold rounded transition-colors no-underline">
                        Our Programmes
                    </a>
                </div>
            </div>

            <!-- Quick donate card -->
            <div class="hidden md:block">
                <div class="bg-white rounded-2xl p-8 shadow-2xl max-w-sm ml-auto">
                    <h3 class="font-['Playfair_Display',serif] text-2xl font-bold text-[#1C1A17] mb-1">Choose Your Donation</h3>
                    <p class="text-sm text-[#6B6459] mb-6">Every penny changes a life.</p>
                    <div class="space-y-4">
                        <a asp-page="/Donate/Index" class="block w-full py-3 bg-[#1A5C6B] hover:bg-[#154D5A] text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2 no-underline">
                            Proceed to Donate <i class="ph ph-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats bar -->
        <div class="absolute bottom-0 left-0 right-0 bg-black/30 backdrop-blur-sm">
            <div class="max-w-7xl mx-auto px-6 py-4 grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="text-center">
                    <div class="font-['Playfair_Display',serif] text-2xl font-bold text-[#E8C07D]">1.2M+</div>
                    <div class="text-xs text-white/60 uppercase tracking-wide">Lives Touched</div>
                </div>
                <div class="text-center">
                    <div class="font-['Playfair_Display',serif] text-2xl font-bold text-[#E8C07D]">48</div>
                    <div class="text-xs text-white/60 uppercase tracking-wide">NGO Partners</div>
                </div>
                <div class="text-center">
                    <div class="font-['Playfair_Display',serif] text-2xl font-bold text-[#E8C07D]">12</div>
                    <div class="text-xs text-white/60 uppercase tracking-wide">Countries Reached</div>
                </div>
                <div class="text-center">
                    <div class="font-['Playfair_Display',serif] text-2xl font-bold text-[#E8C07D]">240+</div>
                    <div class="text-xs text-white/60 uppercase tracking-wide">Programmes Run</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Causes section -->
    <section class="bg-[#F6F1E9] py-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-12 items-end mb-14">
                <div>
                    <p class="text-[#C97C2E] font-semibold text-sm uppercase tracking-widest mb-3">What We Support</p>
                    <h2 class="font-['Playfair_Display',serif] text-4xl md:text-5xl font-bold text-[#1C1A17] leading-tight">Causes That<br /><span class="italic text-[#1A5C6B]">Matter</span></h2>
                </div>
                <p class="text-[#6B6459] leading-relaxed">
                    Donations are directed to specific causes managed by verified NGO partners. Choose what moves you most — every contribution is tracked transparently.
                </p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
                <a asp-page="/Donate/Index" class="border rounded-xl p-5 flex flex-col items-center gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 bg-blue-50 text-blue-700 border-blue-200 no-underline">
                    <i class="ph ph-baby text-3xl"></i><span class="text-sm font-semibold">Children</span>
                </a>
                <a asp-page="/Donate/Index" class="border rounded-xl p-5 flex flex-col items-center gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 bg-green-50 text-green-700 border-green-200 no-underline">
                    <i class="ph ph-graduation-cap text-3xl"></i><span class="text-sm font-semibold">Education</span>
                </a>
                <a asp-page="/Donate/Index" class="border rounded-xl p-5 flex flex-col items-center gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 bg-purple-50 text-purple-700 border-purple-200 no-underline">
                    <i class="ph ph-wheelchair-motion text-3xl"></i><span class="text-sm font-semibold">Disabled</span>
                </a>
                <a asp-page="/Donate/Index" class="border rounded-xl p-5 flex flex-col items-center gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 bg-rose-50 text-rose-700 border-rose-200 no-underline">
                    <i class="ph ph-heart text-3xl"></i><span class="text-sm font-semibold">Health</span>
                </a>
                <a asp-page="/Donate/Index" class="border rounded-xl p-5 flex flex-col items-center gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 bg-pink-50 text-pink-700 border-pink-200 no-underline">
                    <i class="ph ph-user-check text-3xl"></i><span class="text-sm font-semibold">Women</span>
                </a>
            </div>
        </div>
    </section>

    <!-- About strip -->
    <section class="bg-[#1C1A17] py-20">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=700&h=500&fit=crop&auto=format" alt="Volunteers working" class="rounded-xl w-full object-cover h-80 opacity-90" />
                <div class="absolute -bottom-6 -right-6 bg-[#C97C2E] text-white p-5 rounded-xl shadow-xl">
                    <div class="font-['Playfair_Display',serif] text-3xl font-bold">24+</div>
                    <div class="text-xs uppercase tracking-wide opacity-90">Years of Service</div>
                </div>
            </div>
            <div>
                <p class="text-[#C97C2E] text-sm font-semibold uppercase tracking-widest mb-3">About Give-AID</p>
                <h2 class="font-['Playfair_Display',serif] text-4xl font-bold text-white leading-tight mb-6">Established by Major Companies, Driven by <span class="italic text-[#E8C07D]">Compassion</span></h2>
                <p class="text-white/60 leading-relaxed mb-6">
                    Give-AID was founded with contributions from leading corporations who believed that profit must coexist with purpose. We coordinate welfare activities across India and beyond, bringing structured funding to those who need it most.
                </p>
                <a asp-page="/About" class="flex items-center gap-2 text-[#E8C07D] font-semibold hover:gap-3 transition-all no-underline">
                    Read our story <i class="ph ph-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#C97C2E] py-20">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="font-['Playfair_Display',serif] text-4xl md:text-5xl font-bold text-white mb-4">Join the Movement</h2>
            <p class="text-white/80 text-lg mb-8">Register today to donate, invite friends, and stay connected with every programme we run.</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a asp-page="/Register" class="px-8 py-4 bg-white text-[#C97C2E] font-bold rounded hover:bg-[#F6F1E9] transition-colors no-underline">
                    Create an Account
                </a>
                <a asp-page="/Donate/Index" class="px-8 py-4 bg-transparent border-2 border-white text-white font-bold rounded hover:bg-white/10 transition-colors no-underline">
                    Donate Directly
                </a>
            </div>
        </div>
    </section>
</div>