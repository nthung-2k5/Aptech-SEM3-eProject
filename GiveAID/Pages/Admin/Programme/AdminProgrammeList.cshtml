@model AdminProgrammeList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3] flex justify-between items-center">
        <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17]">Welfare Programmes</h3>
        <a href="/Admin/Programme/Editor"
           class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A] no-underline">
            <i class="ph ph-plus"></i> Add Programme
        </a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-[#F6F1E9]">
            <tr>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Name</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">NGO</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Cause</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Location</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Raised / Target</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Period</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Status</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Programmes)
            {
                var now = DateTimeOffset.UtcNow;
                var statusLabel = p.EndDate.HasValue && p.EndDate < now ? "Ended"
                    : p.StartDate > now ? "Upcoming"
                    : "Active";
                var statusCss = statusLabel == "Active" ? "bg-emerald-100 text-emerald-700"
                    : statusLabel == "Upcoming" ? "bg-blue-100 text-blue-700"
                    : "bg-gray-100 text-gray-600";

                <tr class="border-t border-[#E3DDD3] hover:bg-[#F6F1E9]">
                    <td class="px-5 py-3.5">
                        <div class="flex items-center gap-3">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" class="w-9 h-9 rounded object-cover shrink-0"/>
                            }
                            <span class="text-sm font-semibold text-[#1C1A17]">@p.Name</span>
                        </div>
                    </td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@p.Ngo</td>
                    <td class="px-5 py-3.5 text-sm">
                        <span class="bg-[#1A5C6B]/10 text-[#1A5C6B] text-xs font-semibold px-2 py-0.5 rounded-full">@p.Cause</span>
                    </td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@(p.Location ?? "—")</td>
                    <td class="px-5 py-3.5 text-sm">
                        <span class="text-[#1A5C6B] font-semibold">$@p.RaisedAmount.ToString("N0")</span>
                        @if (p.TargetAmount.HasValue)
                        {
                            <span class="text-[#6B6459]"> / $@p.TargetAmount.Value.ToString("N0")</span>
                        }
                        else
                        {
                            <span class="text-[#6B6459]"> / —</span>
                        }
                    </td>
                    <td class="px-5 py-3.5 text-xs text-[#6B6459]">
                        @p.StartDate.ToString("MMM dd, yyyy")<br/>
                        @(p.EndDate.HasValue ? "→ " + p.EndDate.Value.ToString("MMM dd, yyyy") : "→ ongoing")
                    </td>
                    <td class="px-5 py-3.5">
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full @statusCss">@statusLabel</span>
                    </td>
                    <td class="px-5 py-3.5 text-sm flex gap-2">
                        <a href="/Admin/Programme/Editor/@p.Id" class="text-blue-500 hover:text-blue-700" title="Edit">
                            <i class="ph ph-pencil-simple"></i>
                        </a>
                        <button on:click="@(() => Model.Delete(p.Id))" class="text-red-500 hover:text-red-700"
                                title="Delete">
                            <i class="ph ph-trash"></i>
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Programmes.Length == 0)
        {
            <div class="p-8 text-center text-[#6B6459] text-sm">
                No programmes found. Click "Add Programme" to create one.
            </div>
        }
    </div>
</div>
