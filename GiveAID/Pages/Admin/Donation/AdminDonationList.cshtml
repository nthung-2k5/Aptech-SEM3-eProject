@using GiveAID.Models
@model AdminDonationList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3] flex justify-between items-center">
        <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17]">Donation Records</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full table">
            <thead>
            <tr>
                <th>Donor</th>
                <th>Target</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var d in Model.Donations)
            {
                <tr>
                    <th>
                        <button on:click="@(() => Model.ShowMemberInfo(d.DonorId))"
                                class="text-[#1A5C6B] cursor-pointer hover:text-[#154D5A] text-left font-semibold transition-colors"
                                title="View member profile">
                            @d.DonorName
                        </button>
                    </th>
                    <td>
                        @{
                            if (d.Target.TryPickT0(out var ngo, out var prog))
                            {
                                <span class="font-medium text-[#1C1A17]">@ngo.Ngo.Name</span>
                        
                                if (ngo.Cause.HasValue)
                                {
                                    <span
                                        class="ml-1 bg-[#1A5C6B]/10 text-[#1A5C6B] text-xs font-semibold px-2 py-0.5 rounded-full">@ngo.Cause.Value.Name</span>
                                }
                            }
                            else
                            {
                                <span class="font-medium text-[#4A8B7F]">
                                    <i class="ph ph-flag mr-1"></i>@prog.ProgrammeName
                                </span>
                            }
                        }
                    </td>
                    <td class="font-medium">$@d.Amount.ToString("N2")</td>
                    <td class="px-5 py-3.5 text-sm">
                        @if (d.Status == DonationStatus.Completed)
                        {
                            <span
                                class="bg-emerald-100 text-emerald-700 text-xs font-semibold px-2.5 py-1 rounded-full">Completed</span>
                        }
                        else
                        {
                            <span
                                class="bg-red-100 text-red-700 text-xs font-semibold px-2.5 py-1 rounded-full">Void</span>
                        }
                    </td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@d.DonationDate.ToString("MMM dd, yyyy")</td>
                    <td class="px-5 py-3.5">
                        @if (d.Status == DonationStatus.Completed)
                        {
                            <button on:click="@(() => Model.Void(d.Id))" class="btn btn-outline btn-error btn-sm"
                                    title="Void this donation">
                                <i class="ph ph-x-circle"></i>Void
                            </button>
                        }
                        else { <span class="text-[#6B6459] text-xs">—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Donations.Length == 0)
        {
            <div class="p-8 text-center text-[#6B6459] text-sm">No donation records
                found.
            </div>
        }
    </div>

    <user-info-modal is-open="@Model.OpenModal" member="@Model.SelectedMember" close="@(() => Model.CloseModal())"/>
</div>
