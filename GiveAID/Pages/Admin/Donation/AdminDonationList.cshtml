@using GiveAID.Models
@model AdminDonationList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3]">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <h3 class="text-[#1C1A17]">Donation Records</h3>
            <span class="badge badge-ghost text-sm">@Model.TotalCount total</span>
        </div>

        <div class="flex flex-wrap gap-3 items-end">
            <div>
                <label class="label label-text text-xs font-semibold text-[#6B6459] mb-1">From</label>
                <input type="date" asp-for="DateFrom" bind
                       on:change="@(() => Model.Search())"
                       class="input input-bordered input-sm" />
            </div>
            <div>
                <label class="label label-text text-xs font-semibold text-[#6B6459] mb-1">To</label>
                <input type="date" asp-for="DateTo" bind
                       on:change="@(() => Model.Search())"
                       class="input input-bordered input-sm" />
            </div>
            <div>
                <label class="label label-text text-xs font-semibold text-[#6B6459] mb-1">Status</label>
                <select asp-for="StatusFilter" bind on:change="@(() => Model.Search())" class="select select-bordered select-sm">
                    <option value="">All Statuses</option>
                    <option value="Completed">Completed</option>
                    <option value="Void">Void</option>
                </select>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="table w-full">
            <thead>
            <tr>
                <th>Donor</th>
                <th>Target</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date/Time (GMT)</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var d in Model.Donations)
            {
                <tr>
                    <th>
                        <button on:click="@(() => Model.ShowMemberInfo(d.DonorId))"
                                class="text-[#1A5C6B] cursor-pointer hover:text-[#154D5A] text-left font-semibold transition-colors"
                                title="View member profile">
                            @d.DonorName
                        </button>
                    </th>
                    <td>
                        @{
                            if (d.Target.TryPickT0(out var ngo, out var prog))
                            {
                                <span class="font-medium text-[#1C1A17]">@ngo.Ngo.Name</span>

                                if (ngo.Cause.HasValue)
                                {
                                    <span class="ml-1 badge badge-ghost text-xs">@ngo.Cause.Value.Name</span>
                                }
                            }
                            else
                            {
                                <span class="font-medium text-[#4A8B7F]">
                                    <i class="ph ph-flag mr-1"></i>@prog.ProgrammeName
                                </span>
                            }
                        }
                    </td>
                    <td class="font-medium">@d.Amount.ToUsCurrencyString()</td>
                    <td>
                        @if (d.Status == DonationStatus.Completed)
                        {
                            <span class="badge badge-success badge-soft">Completed</span>
                        }
                        else
                        {
                            <span class="badge badge-error badge-soft">Void</span>
                        }
                    </td>
                    <td class="text-sm text-[#6B6459]">@d.DonationDate.ToString("g")</td>
                    <td>
                        @if (d.Status == DonationStatus.Completed)
                        {
                            <button on:click="@(() => Model.Void(d.Id))" class="btn btn-outline btn-error btn-xs"
                                    title="Void this donation">
                                <i class="ph ph-x-circle"></i> Void
                            </button>
                        }
                        else { <span class="text-[#6B6459] text-xs">—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Donations.Length == 0)
        {
            <div class="p-8 text-center text-[#6B6459] text-sm">
                No donation records found.
            </div>
        }
    </div>
    
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#E3DDD3]">
        <span class="text-sm text-[#6B6459]">
            @if (Model.TotalPages > 1)
            {
                <text>Page @Model.PageNumber of @Model.TotalPages</text>
            }
            <text> &ndash; @Model.TotalCount record(s)</text>
        </span>
        @if (Model.TotalPages > 1)
        {
            <div class="join">
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber - 1))"
                        disabled="@(!Model.HasPreviousPage)">
                    <i class="ph ph-caret-left"></i>
                </button>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    int p = i;
                    <button class="join-item btn btn-sm @(p == Model.PageNumber ? "btn-active" : "")"
                            on:click="@(() => Model.GoToPage(p))">
                        @p
                    </button>
                }
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber + 1))"
                        disabled="@(!Model.HasNextPage)">
                    <i class="ph ph-caret-right"></i>
                </button>
            </div>
        }
    </div>

    <user-info-modal is-open="@Model.OpenModal" member="@Model.SelectedMember" close="@(() => Model.CloseModal())"/>
</div>
