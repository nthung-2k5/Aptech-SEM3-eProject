@model AdminPartnerEditor

<form on:submit="@(() => Model.Save())" class="bg-white border border-[#E3DDD3] rounded-xl p-6">
    <h4 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17] mb-4">@(Model.Id.HasValue ? "Edit Partner" : "Add Partner")</h4>
    <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Name <span
                    class="text-red-500">*</span></label>
            <input type="text" asp-for="Form.Name" required
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Logo URL</label>
            <input type="url" asp-for="Form.LogoUrl" placeholder="https://example.com/logo.png"
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Website Link</label>
            <input type="url" asp-for="Form.WebsiteLink" placeholder="https://example.com"
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Form.LogoUrl))
            {
                <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Logo Preview</label>
                <div
                    class="border border-[#E3DDD3] rounded-lg p-3 bg-[#F6F1E9] flex items-center justify-center h-[42px]">
                    <img src="@Model.Form.LogoUrl" alt="Logo preview" class="max-h-full max-w-full object-contain"/>
                </div>
            }
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Description</label>
            <textarea asp-for="Form.Description" rows="3" placeholder="Describe the partner organization..."
                      class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"></textarea>
        </div>
    </div>
    <div class="flex gap-2">
        <button type="submit"
                class="px-5 py-2.5 bg-[#C97C2E] text-white font-semibold rounded-lg text-sm hover:bg-[#B06B20]">Save
            Partner
        </button>
        <a href="/Admin/Partner"
           class="px-5 py-2.5 bg-gray-200 text-gray-800 font-semibold rounded-lg text-sm hover:bg-gray-300 no-underline">Cancel</a>
    </div>
</form>
