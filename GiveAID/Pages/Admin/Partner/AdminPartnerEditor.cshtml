@model AdminPartnerEditor

<form on:submit="@(() => Model.Save())" class="bg-white border border-[#E3DDD3] rounded-xl p-6">
    <h4 class="font-bold text-[#1C1A17] mb-4">@(Model.Id.HasValue ? "Edit Partner" : "Add Partner")</h4>
    <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Name <span
                    class="text-red-500">*</span></label>
            <input type="text" asp-for="Form.Name" bind required class="input w-full"/>
            <span asp-validation-for="Form.Name"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Logo URL</label>
            <input type="url" asp-for="Form.LogoUrl" bind placeholder="https://example.com/logo.png" required class="input w-full"/>
            <span asp-validation-for="Form.LogoUrl"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Website Link</label>
            <input type="url" asp-for="Form.WebsiteLink" bind placeholder="https://example.com" required class="input w-full"/>
            <span asp-validation-for="Form.WebsiteLink"></span>
        </div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Form.LogoUrl))
            {
                <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Logo Preview</label>
                <div
                    class="border border-[#E3DDD3] rounded-lg p-3 bg-[#F6F1E9] flex items-center justify-center h-[42px]">
                    <img src="@Model.Form.LogoUrl" alt="Logo preview" class="max-h-full max-w-full object-contain"/>
                </div>
            }
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Description</label>
            <textarea asp-for="Form.Description" bind rows="3" placeholder="Describe the partner organization..."
                      class="textarea w-full"></textarea>
            <span asp-validation-for="Form.Description"></span>
        </div>
    </div>
    <div class="flex justify-end gap-2">
        <a asp-page="/Admin/Partner/Index" class="btn btn-soft">Cancel</a>
        <button type="submit" class="btn btn-secondary">Save Partner</button>
    </div>
</form>
