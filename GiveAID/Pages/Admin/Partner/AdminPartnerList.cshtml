@model AdminPartnerList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3]">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-[#1C1A17]">Corporate Partners</h3>
              <span class="badge badge-lg bg-[#1A5C6B]/10 text-[#1A5C6B] border-0 font-semibold"><i class="ph ph-handshake mr-1"></i> @Model.TotalCount total</span>
              <span class="badge badge-lg bg-[#4A8B7F]/10 text-[#4A8B7F] border-0 font-semibold"><i class="ph ph-book-open mr-1"></i> @Model.TotalPages page(s)</span>
            </div>
            <a asp-page="/Admin/Partner/Editor" class="btn btn-primary btn-sm">
                <i class="ph ph-plus"></i> Add Partner
            </a>
        </div>

        <div class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[200px]">
                <label class="label label-text text-sm font-semibold text-[#6B6459] mb-1">Search by Name</label>
                <label class="input input-bordered flex items-center gap-2 w-full">
                    <i class="ph ph-magnifying-glass text-[#6B6459]"></i>
                    <input type="text" asp-for="SearchTerm" bind:keydown.debounce.300ms
                           on:input="@(() => Model.Search())"
                           placeholder="Partner name…" />
                </label>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="table w-full">
            <thead class="text-[#6B6459] text-xs font-bold uppercase tracking-wider bg-[#F6F1E9]/50">
            <tr>
                <th class="py-4 pl-6 w-1/2">Partner Name</th>
                <th class="py-4">Website</th>
                <th class="py-4 pr-6 text-right w-32">Actions</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-[#E3DDD3]">
            @foreach (var p in Model.Partners)
            {
                <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="py-4 pl-6">
                        <div class="flex items-center gap-3">
                            <div class="size-10 bg-[#1A5C6B]/10 rounded-xl flex items-center justify-center shrink-0 text-[#1A5C6B]">
                                <i class="ph-fill ph-handshake text-xl"></i>
                            </div>
                            <span class="font-semibold text-[#1C1A17] text-base">@p.Name</span>
                        </div>
                    </td>
                    <td class="py-4">
                        @if (!string.IsNullOrEmpty(p.WebsiteLink))
                        {
                            <a href="@p.WebsiteLink" target="_blank" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[#F6F1E9] hover:bg-[#E3DDD3] text-[#1A5C6B] text-sm font-medium rounded-lg transition-colors no-underline">
                                <i class="ph ph-link text-lg"></i> Visit Site
                            </a>
                        }
                        else { <span class="text-[#6B6459] text-sm italic">Not provided</span> }
                    </td>
                    <td class="py-4 pr-6">
                        <div class="flex items-center justify-end gap-1" x-data="{ confirmDelete() { Swal.fire({ title: 'Are you sure?', text: 'This action cannot be undone.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', cancelButtonColor: '#3085d6', confirmButtonText: 'Yes, delete it!' }).then((result) => { if (result.isConfirmed) { $refs.deleteBtn.click(); } }) } }">
                            <a asp-page="/Admin/Partner/Editor" asp-route-id="@p.Id" asp-route-mode="view" class="btn btn-ghost btn-sm text-[#1A5C6B] hover:bg-[#1A5C6B]/10" title="View details">
                                <i class="ph ph-eye text-lg"></i>
                            </a>
                            <a asp-page="/Admin/Partner/Editor" asp-route-id="@p.Id" class="btn btn-ghost btn-sm text-[#C97C2E] hover:bg-[#C97C2E]/10" title="Edit">
                                <i class="ph ph-pencil-simple text-lg"></i>
                            </a>
                            <button @@click.prevent="confirmDelete()" class="btn btn-ghost btn-sm text-red-500 hover:bg-red-50"
                                    title="Delete"><i class="ph ph-trash text-lg"></i></button>
                            <button x-ref="deleteBtn" on:click="@(() => Model.Delete(p.Id))" style="display:none;"></button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Partners.Length == 0)
        {
            <div class="p-8 text-center text-[#6B6459] text-sm">
                No partners found. Click "Add Partner" to create one.
            </div>
        }
    </div>
    
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#E3DDD3]">
        <span class="text-sm text-[#6B6459]">
            @if (Model.TotalPages > 1)
            {
                <text>Page @Model.PageNumber of @Model.TotalPages &ndash; </text>
            }
            @Model.TotalCount record(s)
        </span>
        @if (Model.TotalPages > 1)
        {
            <div class="join">
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber - 1))"
                        disabled="@(!Model.HasPreviousPage)">
                    <i class="ph ph-caret-left"></i>
                </button>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    int p = i;
                    <button class="join-item btn btn-sm @(p == Model.PageNumber ? "btn-active" : "")"
                            on:click="@(() => Model.GoToPage(p))">
                        @p
                    </button>
                }
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber + 1))"
                        disabled="@(!Model.HasNextPage)">
                    <i class="ph ph-caret-right"></i>
                </button>
            </div>
        }
    </div>
</div>
