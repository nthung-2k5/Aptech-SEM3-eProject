@model AdminMemberList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3]">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <h3 class="text-[#1C1A17]">Registered Members</h3>
            <div class="flex items-center gap-3">
                <span class="badge badge-ghost text-sm font-medium">@Model.TotalCount Members</span>
                <a asp-page="/Admin/Member/Editor" class="btn btn-primary btn-sm">
                    <i class="ph ph-plus"></i> Add Member
                </a>
            </div>
        </div>

        <div class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[200px]">
                <label class="label label-text text-xs font-semibold text-[#6B6459] mb-1">Search by Name, Email, or Phone</label>
                <label class="input input-bordered input-sm flex items-center gap-2 w-full">
                    <i class="ph ph-magnifying-glass text-[#6B6459]"></i>
                    <input type="text" asp-for="SearchTerm" bind:keydown.debounce.300ms
                           on:input="@(() => Model.Search())"
                           placeholder="Name, email, or phone…" />
                </label>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="table w-full">
            <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Date of Birth</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.Members)
            {
                <tr>
                    <th>@m.FullName</th>
                    <td>@m.Email</td>
                    <td>@m.PhoneNumber</td>
                    <td>@m.DateOfBirth.ToShortDateString()</td>
                    <td>
                        <div class="flex gap-1">
                            <button on:click="@(() => Model.ShowMemberInfo(m.Id))"
                                    class="btn btn-ghost btn-xs"
                                    title="View profile">
                                <i class="ph ph-eye"></i>
                            </button>
                            <a asp-page="/Admin/Member/Editor" asp-route-id="@m.Id" class="btn btn-ghost btn-xs" title="Edit">
                                <i class="ph ph-pencil-simple"></i>
                            </a>
                            <button on:click="@(() => Model.Delete(m.Id))"
                                    class="btn btn-ghost btn-xs text-error"
                                    title="Delete"><i class="ph ph-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Members.Length == 0)
        {
            <div class="p-8 text-center text-[#6B6459] text-sm">No members found.</div>
        }
    </div>
    
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#E3DDD3]">
        <span class="text-sm text-[#6B6459]">
            @if (Model.TotalPages > 1)
            {
                <text>Page @Model.PageNumber of @Model.TotalPages &ndash; </text>
            }
            @Model.TotalCount record(s)
        </span>
        @if (Model.TotalPages > 1)
        {
            <div class="join">
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber - 1))"
                        disabled="@(!Model.HasPreviousPage)">
                    <i class="ph ph-caret-left"></i>
                </button>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    int p = i;
                    <button class="join-item btn btn-sm @(p == Model.PageNumber ? "btn-active" : "")"
                            on:click="@(() => Model.GoToPage(p))">
                        p
                    </button>
                }
                <button class="join-item btn btn-sm"
                        on:click="@(() => Model.GoToPage(Model.PageNumber + 1))"
                        disabled="@(!Model.HasNextPage)">
                    <i class="ph ph-caret-right"></i>
                </button>
            </div>
        }
    </div>

    <user-info-modal is-open="@Model.OpenModal" member="@Model.SelectedMember" close="@(() => Model.CloseModal())"/>
</div>
