@using GiveAID.Pages.Admin.Components
@model AdminMemberList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3] flex justify-between items-center">
        <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17]">Registered Members</h3>
        <a asp-page="/Admin/Member/Editor"
           class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A] no-underline">
            <i class="ph ph-plus"></i> Add Member
        </a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Date of Birth</th>
                <th>Occupation</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.Members)
            {
                <tr >
                    <th>@m.FullName</th>
                    <td>@m.Email</td>
                    <td>@m.PhoneNumber</td>
                    <td>@m.DateOfBirth.ToString("MMM dd, yyyy")</td>
                    <td>@m.Occupation</td>
                    <td class="flex gap-2">
                        <button on:click="@(() => Model.ShowMemberInfo(m.Id))"
                                class="text-[#6B6459] hover:text-[#1A5C6B] size-4 transition-colors"
                                title="View profile">
                            <i class="ph ph-eye"></i>
                        </button>
                        <a asp-page="/Admin/Member/Editor" asp-route-id="@m.Id"
                           class="edit-button" title="Edit"><i
                                class="ph ph-pencil-simple"></i></a>
                        <button on:click="@(() => Model.Delete(m.Id))"
                                class="delete-button"
                                title="Delete"><i class="ph ph-trash"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Members.Length == 0) { <div class="p-8 text-center text-[#6B6459] text-sm">No members found.</div> }
    </div>

    <user-info-modal is-open="@Model.OpenModal" member="@Model.SelectedMember" close="@(() => Model.CloseModal())"/>
</div>
