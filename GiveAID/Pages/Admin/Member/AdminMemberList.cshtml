@model AdminMemberList

<div class="bg-white rounded-xl border border-[#E3DDD3] overflow-hidden">
    <div class="p-6 border-b border-[#E3DDD3] flex justify-between items-center">
        <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17]">Registered Members</h3>
        <a href="/Admin/Member/Editor"
           class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A] no-underline">
            <i class="ph ph-plus"></i> Add Member
        </a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-[#F6F1E9]">
            <tr>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Name</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Email</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Phone</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Date of Birth
                </th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Occupation</th>
                <th class="text-left text-xs font-bold text-[#6B6459] uppercase tracking-wide px-5 py-3">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var m in Model.Members)
            {
                <tr class="border-t border-[#E3DDD3] hover:bg-[#F6F1E9]">
                    <td class="px-5 py-3.5 text-sm font-semibold text-[#1C1A17]">@m.FullName</td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@m.Email</td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@m.PhoneNumber</td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@m.DateOfBirth.ToString("MMM dd, yyyy")</td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459]">@m.Occupation</td>
                    <td class="px-5 py-3.5 text-sm text-[#6B6459] flex gap-2">
                        <a href="/Admin/Member/Editor/@m.Id" class="text-blue-500 hover:text-blue-700" title="Edit"><i
                                class="ph ph-pencil-simple"></i></a>
                        <button on:click="@(() => Model.Delete(m.Id))" class="text-red-500 hover:text-red-700"
                                title="Delete"><i class="ph ph-trash"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Members.Length == 0) { <div class="p-8 text-center text-[#6B6459] text-sm">No members found.</div> }
    </div>
</div>
