@model AdminUserQueryList

<div class="flex gap-5 h-[calc(100vh-240px)] min-h-[480px]">

    @* ===== LEFT PANEL: Query List ===== *@
    <div class="w-80 shrink-0 flex flex-col bg-white border border-[#E3DDD3] rounded-xl overflow-hidden">

        @* Header + Toggle *@
        <div class="p-4 border-b border-[#E3DDD3] shrink-0">
            <div class="flex items-center justify-between mb-3">
                <h3 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17] text-base">User Queries</h3>
                <span class="text-xs font-semibold text-[#6B6459] bg-[#F6F1E9] px-2 py-0.5 rounded-full">
                    @Model.Queries.Length
                </span>
            </div>
            <button on:click="@(() => Model.ToggleFilter())"
                    class="w-full flex items-center justify-between px-3 py-2 rounded-lg border text-sm font-medium transition-colors @(Model.ShowOnlyUnanswered ? "border-[#C97C2E] bg-[#C97C2E]/10 text-[#C97C2E]" : "border-[#E3DDD3] bg-white text-[#6B6459] hover:bg-[#F6F1E9]")">
                <span class="flex items-center gap-1.5">
                    <i class="ph @(Model.ShowOnlyUnanswered ? "ph-funnel-simple" : "ph-funnel-simple-x")"></i>
                    @(Model.ShowOnlyUnanswered ? "Unanswered only" : "All queries")
                </span>
                <i class="ph ph-arrows-counter-clockwise text-xs opacity-60"></i>
            </button>
        </div>

        @* Scrollable list *@
        <div class="flex-1 overflow-y-auto divide-y divide-[#F0EBE3]">
            @if (Model.Queries.Length == 0)
            {
                <div class="p-6 text-center text-[#6B6459] text-sm">
                    <i class="ph ph-check-circle text-2xl text-emerald-400 block mb-2"></i>
                    All queries answered!
                </div>
            }
            @foreach (var q in Model.Queries)
            {
                var isSelected = q.Id == Model.SelectedId;
                var isAnswered = !string.IsNullOrEmpty(q.ReplyText);
                <button on:click="@(() => Model.SelectQuery(q.Id))"
                        class="w-full text-left px-4 py-3.5 transition-colors @(isSelected ? "bg-[#1A5C6B] text-white" : "hover:bg-[#F6F1E9] text-[#1C1A17]")">
                    <div class="flex items-start justify-between gap-2 mb-1">
                        <span class="text-sm font-semibold leading-snug truncate">@q.Subject</span>
                        <span class="shrink-0 text-[10px] font-bold uppercase px-1.5 py-0.5 rounded-full @(isAnswered ? (isSelected ? "bg-white/20 text-white" : "bg-emerald-100 text-emerald-700") : (isSelected ? "bg-white/20 text-white" : "bg-amber-100 text-amber-700"))">
                            @(isAnswered ? "Done" : "Open")
                        </span>
                    </div>
                    <div class="text-xs @(isSelected ? "text-white/70" : "text-[#6B6459]") truncate">@q.UserName</div>
                    <div class="text-xs @(isSelected ? "text-white/60" : "text-[#6B6459]/60") mt-0.5">
                        @q.CreatedAt.ToString("MMM dd, yyyy · HH:mm")
                    </div>
                </button>
            }
        </div>
    </div>

    @* ===== RIGHT PANEL: Detail + Reply ===== *@
    <div class="flex-1 min-w-0">
        @if (Model.Selected is { } sel)
        {
            var isAnswered = !string.IsNullOrEmpty(sel.ReplyText);
            <div class="bg-white border border-[#E3DDD3] rounded-xl h-full flex flex-col overflow-hidden">

                @* Query header *@
                <div class="p-6 border-b border-[#E3DDD3] shrink-0">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <h4 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17] text-lg leading-tight">
                            @sel.Subject
                        </h4>
                        <span class="shrink-0 text-xs font-bold uppercase px-2.5 py-1 rounded-full @(isAnswered ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                            @(isAnswered ? "Answered" : "Awaiting reply")
                        </span>
                    </div>
                    @* Sender info *@
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-[#1A5C6B]/10 flex items-center justify-center shrink-0">
                            <i class="ph ph-user text-[#1A5C6B]"></i>
                        </div>
                        <div>
                            <div class="text-sm font-semibold text-[#1C1A17]">@sel.UserName</div>
                            <div class="text-xs text-[#6B6459]">Sent @sel.CreatedAt.ToString("dddd, MMMM dd, yyyy 'at' HH:mm")</div>
                        </div>
                    </div>
                </div>

                @* Scrollable body *@
                <div class="flex-1 overflow-y-auto p-6 space-y-6">

                    @* Message content *@
                    <div>
                        <div class="text-xs font-bold uppercase tracking-widest text-[#6B6459] mb-2">Message</div>
                        <div class="bg-[#F6F1E9] rounded-xl p-4 text-sm text-[#1C1A17] leading-relaxed whitespace-pre-wrap">
                            @sel.MessageText
                        </div>
                    </div>

                    @* Reply section *@
                    <div>
                        <div class="text-xs font-bold uppercase tracking-widest text-[#6B6459] mb-2">
                            @(isAnswered ? "Admin Reply" : "Write Reply")
                        </div>

                        @if (isAnswered)
                        {
                            @* Read-only reply view *@
                            <div class="border border-[#1A5C6B]/30 rounded-xl p-4 bg-[#1A5C6B]/5">
                                <div class="flex items-center gap-2 mb-2">
                                    <i class="ph ph-shield-check text-[#1A5C6B]"></i>
                                    <span class="text-xs font-bold text-[#1A5C6B] uppercase tracking-wide">Admin</span>
                                </div>
                                <p class="text-sm text-[#1C1A17] leading-relaxed whitespace-pre-wrap">@sel.ReplyText</p>
                            </div>
                        }
                        else
                        {
                            @* Editable reply form *@
                            <form on:submit="@(() => Model.Reply())" class="space-y-3">
                                <textarea asp-for="ReplyText" bind
                                          rows="6"
                                          placeholder="Type your reply to @sel.UserName..."
                                          required
                                          class="w-full border border-[#E3DDD3] rounded-xl px-4 py-3 text-sm text-[#1C1A17] focus:outline-none focus:ring-2 focus:ring-[#1A5C6B] resize-none leading-relaxed"></textarea>
                                <span asp-validation-for="ReplyText"></span>
                                <div class="flex justify-end">
                                    <button type="submit"
                                            class="flex items-center gap-2 px-5 py-2.5 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A] transition-colors">
                                        <i class="ph ph-paper-plane-right"></i>
                                        Send Reply
                                    </button>
                                </div>
                            </form>
                        }
                    </div>

                </div>
            </div>
        }
        else
        {
            @* Empty state — nothing selected *@
            <div class="bg-white border border-[#E3DDD3] rounded-xl h-full flex flex-col items-center justify-center text-center p-8">
                <div class="w-16 h-16 rounded-full bg-[#F6F1E9] flex items-center justify-center mb-4">
                    <i class="ph ph-chat-dots text-3xl text-[#C97C2E]"></i>
                </div>
                <h4 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17] mb-1">Select a query</h4>
                <p class="text-sm text-[#6B6459]">Click any item on the left to view its details and reply.</p>
            </div>
        }
    </div>

</div>
