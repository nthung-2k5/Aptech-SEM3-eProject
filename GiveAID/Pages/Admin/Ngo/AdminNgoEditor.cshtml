@model AdminNgoEditor

<form on:submit="@(() => Model.Save())" class="bg-white border border-[#E3DDD3] rounded-xl p-6">
    <h4 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17] mb-4">@(Model.Id.HasValue ? "Edit NGO" : "Add NGO")</h4>
    <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Name <span
                    class="text-red-500">*</span></label>
            <input type="text" asp-for="Form.Name" required
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Phone Number</label>
            <input type="text" asp-for="Form.PhoneNumber" placeholder="Phone number"
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Address</label>
            <input type="text" asp-for="Form.Address" placeholder="Location / Address"
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Website</label>
            <input type="url" asp-for="Form.Website" placeholder="https://example.org"
                   class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"/>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Description</label>
            <textarea asp-for="Form.Description" rows="3" placeholder="Describe the NGO's mission and focus areas..."
                      class="w-full border border-[#E3DDD3] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#1A5C6B]"></textarea>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Corporate Partners</label>
            <div class="border border-[#E3DDD3] rounded-lg p-3 max-h-48 overflow-y-auto space-y-2">
                @if (Model.AvailablePartners.Length == 0)
                {
                    <p class="text-sm text-[#6B6459]">No partners available. <a href="/Admin/Partner/Editor"
                                                                                class="text-[#1A5C6B] hover:underline">Create
                            one</a></p>
                }
                else
                {
                    @foreach (var p in Model.AvailablePartners)
                    {
                        <label
                            class="flex items-center gap-2 cursor-pointer text-sm text-[#1C1A17] hover:bg-[#F6F1E9] p-1 rounded">
                            <input type="checkbox" value="@p.Id"
                                   checked="@Model.Form.SelectedPartnerIds.Contains(p.Id)"
                                   on:change="@(() => Model.TogglePartner(p.Id))"
                                   class="accent-[#1A5C6B] w-4 h-4"/>
                            <span>@p.Name</span>
                        </label>
                    }
                }
            </div>
        </div>
    </div>
    <div class="flex gap-2">
        <button type="submit"
                class="px-5 py-2.5 bg-[#C97C2E] text-white font-semibold rounded-lg text-sm hover:bg-[#B06B20]">Save NGO
        </button>
        <a asp-page="/Admin/Ngo/Index"
           class="px-5 py-2.5 bg-gray-200 text-gray-800 font-semibold rounded-lg text-sm hover:bg-gray-300 no-underline">Cancel</a>
    </div>
</form>
