@model AdminNgoEditor

<form on:submit="@(() => Model.Save())" class="bg-white border border-[#E3DDD3] rounded-xl p-6">
    @{ bool isViewMode = Context.Request.Query["mode"] == "view"; }
    <h4 class="font-bold text-[#1C1A17] mb-4">@(isViewMode ? "View NGO" : (Model.Id.HasValue ? "Edit NGO" : "Add NGO"))</h4>
    <fieldset disabled="@isViewMode">
        <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Name <span
                    class="text-red-500">*</span></label>
            <input type="text" asp-for="Form.Name" bind required class="input w-full"/>
            <span asp-validation-for="Form.Name"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Phone Number</label>
            <input type="text" asp-for="Form.PhoneNumber" bind placeholder="Phone number" class="input w-full"/>
            <span asp-validation-for="Form.PhoneNumber"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Address</label>
            <input type="text" asp-for="Form.Address" bind placeholder="Location / Address" class="input w-full"/>
            <span asp-validation-for="Form.Address"></span>
        </div>
        <div>
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Website</label>
            <input type="url" asp-for="Form.Website" bind placeholder="https://example.org" class="input w-full"/>
            <span asp-validation-for="Form.Website"></span>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Description</label>
            <textarea asp-for="Form.Description" bind rows="3" placeholder="Describe the NGO's mission and focus areas..."
                      class="textarea w-full"></textarea>
            <span asp-validation-for="Form.Description"></span>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-[#1C1A17] mb-1">Corporate Partners</label>
            <div class="border border-[#E3DDD3] rounded-lg p-3 max-h-48 overflow-y-auto space-y-2">
                @if (Model.AvailablePartners.Length == 0)
                {
                    <p class="text-sm text-[#6B6459]">No partners available. <a asp-page="/Admin/Partner/Editor"
                                                                                class="text-[#1A5C6B] hover:underline">Create
                            one</a></p>
                }
                else
                {
                    @foreach (var p in Model.AvailablePartners)
                    {
                        <label
                            class="flex items-center gap-2 cursor-pointer text-sm text-[#1C1A17] hover:bg-[#F6F1E9] p-1 rounded">
                            <input type="checkbox" value="@p.Id"
                                   checked="@Model.Form.SelectedPartnerIds.Contains(p.Id)"
                                   on:change="@(() => Model.TogglePartner(p.Id))"
                                   class="accent-[#1A5C6B] w-4 h-4"/>
                            <span>@p.Name</span>
                        </label>
                    }
                }
            </div>
        </div>
        </div>
    </fieldset>
    <div class="flex justify-end gap-2">
        <a asp-page="/Admin/Ngo/Index" class="btn btn-soft">@(isViewMode ? "Back" : "Cancel")</a>
        @if (!isViewMode)
        {
            <button type="submit" class="btn btn-secondary">Save NGO</button>
        }
    </div>
</form>
