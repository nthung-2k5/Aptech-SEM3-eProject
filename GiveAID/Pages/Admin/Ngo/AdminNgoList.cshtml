@model AdminNgoList

<div class="space-y-5">
    <div class="flex justify-between items-center bg-white p-6 rounded-xl border border-[#E3DDD3]">
        <h3 class="font-['Playfair_Display',serif] text-xl font-bold text-[#1C1A17]">Associated NGOs</h3>
        <a href="/Admin/Ngo/Editor"
           class="flex items-center gap-2 px-4 py-2 bg-[#1A5C6B] text-white text-sm font-semibold rounded-lg hover:bg-[#154D5A] no-underline">
            <i class="ph ph-plus"></i> Add NGO
        </a>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
        @foreach (var n in Model.Ngos)
        {
            <div class="bg-white border border-[#E3DDD3] rounded-xl p-5">
                <div class="flex items-start justify-between mb-2">
                    <div>
                        <h4 class="font-['Playfair_Display',serif] font-bold text-[#1C1A17]">@n.Name</h4>
                        <p class="text-sm text-[#C97C2E] line-clamp-2">@n.Description</p>
                    </div>
                    <div class="flex gap-2 shrink-0">
                        <a href="/Admin/Ngo/Editor/@n.Id" class="p-2 text-[#6B6459] hover:text-blue-500" title="Edit"><i
                                class="ph ph-pencil-simple w-4 h-4"></i></a>
                        <button on:click="@(() => Model.Delete(n.Id))" class="p-2 text-[#6B6459] hover:text-red-500"
                                title="Delete"><i class="ph ph-trash w-4 h-4"></i></button>
                    </div>
                </div>
            </div>
        }
    </div>
    @if (Model.Ngos.Length == 0)
    {
        <div class="bg-white border border-[#E3DDD3] rounded-xl p-8 text-center text-[#6B6459] text-sm">
            No NGOs found. Click "Add NGO" to create one.
        </div>
    }
</div>
