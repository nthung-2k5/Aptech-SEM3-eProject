@page "/Admin"
@model IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-6">
    <dashboard-metrics />
    <admin-action-tables />
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function initCharts() {
    const teal   = 'rgba(26,  92, 107, 0.85)';
    const tealBg = 'rgba(26,  92, 107, 0.12)';
    const amber  = 'rgba(201,124, 46, 0.85)';
    const amberBg= 'rgba(201,124, 46, 0.12)';
    const green  = 'rgba(74, 139,127, 0.85)';
    const red    = 'rgba(212, 24, 61, 0.85)';
    const palette = [teal, amber, green, red,
                     'rgba(107,100,89,0.85)', 'rgba(80,160,100,0.85)'];

    function parseCanvas(id) {
        const el = document.getElementById(id);
        if (!el) return null;
        return {
            el,
            labels: JSON.parse(el.dataset.chartLabels || '[]'),
            data:   JSON.parse(el.dataset.chartData   || '[]')
        };
    }

    // Chart 1 – Donation Trends (Line)
    const d1 = parseCanvas('donationTrendChart');
    if (d1) {
        new Chart(d1.el, {
            type: 'line',
            data: {
                labels: d1.labels,
                datasets: [{
                    label: 'Revenue ($)',
                    data: d1.data,
                    borderColor: teal,
                    backgroundColor: tealBg,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: teal
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { callback: v => '$' + v } } }
            }
        });
    }

    // Chart 2 – Campaign Causes (Doughnut)
    const d2 = parseCanvas('campaignDistributionChart');
    if (d2) {
        new Chart(d2.el, {
            type: 'doughnut',
            data: {
                labels: d2.labels,
                datasets: [{
                    data: d2.data,
                    backgroundColor: palette,
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'right' } },
                cutout: '60%'
            }
        });
    }

    // Chart 3 – NGO Growth (Bar)
    const d3 = parseCanvas('ngoGrowthChart');
    if (d3) {
        new Chart(d3.el, {
            type: 'bar',
            data: {
                labels: d3.labels,
                datasets: [{
                    label: 'New NGOs',
                    data: d3.data,
                    backgroundColor: amber,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });
    }

    // Chart 4 – User Acquisition (Line)
    const d4 = parseCanvas('userAcquisitionChart');
    if (d4) {
        new Chart(d4.el, {
            type: 'line',
            data: {
                labels: d4.labels,
                datasets: [{
                    label: 'New Members',
                    data: d4.data,
                    borderColor: red,
                    backgroundColor: 'rgba(212,24,61,0.10)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: red
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });
    }
})();
</script>
}
