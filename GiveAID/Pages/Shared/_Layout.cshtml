@using System.Security.Claims
@using GiveAID.Services.Abstractions
<!DOCTYPE html>
<html lang="en">
@inject IAboutUsSubpageService AboutUsSubpageService
@inject INotificationService NotificationService
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - GiveAID</title>
    <script type="importmap"></script>

    <!-- Hydro Components -->
    <meta name="hydro-config"/>
    <script defer src="~/hydro/hydro.js" asp-append-version="true"></script>
    <script defer src="~/hydro/alpine.js" asp-append-version="true"></script>

    <!-- Tailwind-compiled CSS -->
    <link rel="stylesheet" href="~/app.css" asp-append-version="true"/>

    <link rel="stylesheet" href="~/GiveAID.styles.css" asp-append-version="true"/>

    <!-- Sweetalert 2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.25/dist/sweetalert2.all.min.js"
            integrity="sha256-Tobw4i5HcbW4qsJMYTxmGAameLGvooTQPPatA9PiGgo=" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.25/dist/sweetalert2.min.css"
          integrity="sha256-oRc+Vv1HS+BN2++oG9dcxGVifvL12yYXkufSX7eHF0M=" crossorigin="anonymous">

    <!-- Phosphor Icons -->
    <link
        rel="stylesheet"
        type="text/css"
        href="https://cdn.jsdelivr.net/npm/@@phosphor-icons/web@2.1.1/src/regular/style.css"
    />
    <link
        rel="stylesheet"
        type="text/css"
        href="https://cdn.jsdelivr.net/npm/@@phosphor-icons/web@2.1.1/src/fill/style.css"
    />
</head>
<body>

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#1A5C6B] text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a asp-page="/Index" class="flex items-center gap-2 group text-white hover:text-white no-underline">
                <div class="size-8 bg-[#C97C2E] rounded-full flex items-center justify-center">
                    <i class="ph-fill ph-heart text-white"></i>
                </div>
                <h3 class="font-bold tracking-tight">Give<span class="text-[#E8C07D]">-AID</span></h3>
            </a>

            <!-- Nav -->
            <nav id="navbar">
                <a asp-page="/Index" class="navbar-button">Home</a>
                <a asp-page="/Programmes/Index" class="navbar-button">Programmes</a>
                <a asp-page="/Partners" class="navbar-button">Our Partners</a>

                <div class="relative group">
                    <a asp-page="/AboutUs/Index" class="navbar-button">
                        About Us
                    </a>
                    <div
                        class="absolute left-0 mt-1 w-56 bg-white text-black shadow-lg rounded-b-md hidden group-hover:block border border-[#E3DDD3]">
                        @foreach (var subpage in await AboutUsSubpageService.ListSubpagesAsync())
                        {
                            <a asp-page="/AboutUs/Index" asp-route-slug="@subpage.Slug"
                               class="block px-4 py-2 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] border-b border-[#E3DDD3] last:border-0 no-underline transition-colors">@subpage.Title</a>
                        }
                    </div>
                </div>

                <a asp-page="/Gallery/Index" class="navbar-button">Gallery</a>

                <div class="relative group">
                    <a href="#" class="navbar-button">
                        Help Centre
                    </a>
                    <div
                        class="absolute left-0 mt-1 w-40 bg-white text-black shadow-lg rounded-b-md hidden group-hover:block border border-[#E3DDD3]">
                        <a asp-page="/Faq"
                           class="block px-4 py-2 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] border-b border-[#E3DDD3] no-underline transition-colors">FAQ</a>
                        <a asp-page="/Contact"
                           class="block px-4 py-2 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] no-underline transition-colors">Contact
                            Us</a>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    bool isMember = User.IsInRole("Member");
                    bool isAdmin = User.IsInRole("Admin");
                    string? userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
                    Guid.TryParse(userIdStr, out var userId);
                    string userName = User.FindFirstValue(ClaimTypes.Name) ?? User.FindFirstValue(ClaimTypes.Email) ?? "User";

                    if (isMember)
                    {
                        int unreadCount = await NotificationService.GetUnreadCountAsync(userId);
                        var notifications = await NotificationService.GetUserNotificationsAsync(userId, 5);

                        <!-- Notifications Dropdown -->
                        <div class="relative group" x-data="{ open: false }">
                            <button @@click="open = !open" @@click.outside="open = false"
                                    class="navbar-button flex items-center gap-1 relative">
                                <i class="ph-fill ph-bell text-lg"></i>
                                @if (unreadCount > 0)
                                {
                                    <span class="absolute top-1 right-1 flex size-2">
                                        <span
                                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full size-2 bg-red-500"></span>
                                    </span>
                                }
                            </button>
                            <div x-show="open" style="display: none;"
                                 class="absolute right-0 mt-2 w-80 bg-white text-black shadow-lg rounded-md border border-[#E3DDD3] overflow-hidden">
                                <div class="flex justify-between items-center p-3 border-b border-[#E3DDD3] bg-gray-50">
                                    <span class="font-bold text-sm">Notifications</span>
                                    @if (unreadCount > 0)
                                    {
                                        <form method="post" asp-page="/Notifications" asp-page-handler="MarkAllRead"
                                              class="m-0">
                                            <button type="submit"
                                                    class="text-xs text-[#1A5C6B] hover:underline font-medium">Mark all
                                                as read
                                            </button>
                                        </form>
                                    }
                                </div>
                                <div class="max-h-64 overflow-y-auto">
                                    @if (notifications.Length == 0) { <div
                                        class="p-6 text-center text-gray-500 text-sm">No notifications yet.
                                    </div> }
                                    else
                                    {
                                        @foreach (var notif in notifications)
                                        {
                                            <form method="post" asp-page="/Notifications" asp-page-handler="MarkRead"
                                                  asp-route-id="@notif.Id" class="block m-0">
                                                <button type="submit"
                                                        class="w-full text-left p-3 border-b border-gray-100 hover:bg-gray-50 transition-colors @(notif.IsRead ? "opacity-60" : "bg-blue-50/50")">
                                                    <p class="text-sm text-gray-800 line-clamp-2">@notif.Content</p>
                                                    <span
                                                        class="text-xs text-gray-400 mt-1 block">@notif.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                                </button>
                                            </form>
                                        }
                                    }
                                </div>
                                <a asp-page="/Notifications"
                                   class="block p-3 text-center text-sm font-medium text-[#C97C2E] hover:bg-gray-50 border-t border-[#E3DDD3]">View
                                    All Notifications</a>
                            </div>
                        </div>

                        <!-- Member Dropdown -->
                        <div class="relative group" x-data="{ open: false }">
                            <button @@click="open = !open" @@click.outside="open = false"
                                    class="navbar-button flex items-center gap-1">
                                <i class="ph-fill ph-user-circle text-xl"></i> @userName
                                <i class="ph ph-caret-down text-xs ml-1"></i>
                            </button>
                            <div x-show="open" style="display: none;"
                                 class="absolute right-0 mt-2 w-48 bg-white text-black shadow-lg rounded-md border border-[#E3DDD3] overflow-hidden">
                                <a asp-page="/Member/Profile"
                                   class="block px-4 py-2.5 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] border-b border-[#E3DDD3] no-underline transition-colors flex items-center gap-2">
                                    <i class="ph ph-user"></i> My Profile
                                </a>
                                <a asp-page="/Member/Donations"
                                   class="block px-4 py-2.5 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] border-b border-[#E3DDD3] no-underline transition-colors flex items-center gap-2">
                                    <i class="ph ph-hand-heart"></i> My Donations
                                </a>
                                <a asp-page="/Member/Interests"
                                   class="block px-4 py-2.5 text-sm text-[#1C1A17] hover:bg-[#F6F1E9] border-b border-[#E3DDD3] no-underline transition-colors flex items-center gap-2">
                                    <i class="ph ph-star"></i> My Interests
                                </a>
                                <form asp-page="/Logout" method="post">
                                    <button type="submit"
                                            class="block px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 no-underline transition-colors flex items-center gap-2">
                                        <i class="ph ph-sign-out"></i> Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else if (isAdmin)
                    {
                        <a asp-page="/Admin/Index" class="navbar-button">Admin Dashboard</a>
                        <form asp-page="/Logout" method="post">
                            <button type="submit"
                                    class="px-3 py-2 text-white/80 hover:text-white text-sm transition-colors no-underline">
                                Logout
                            </button>
                        </form>
                    }
                }
                else
                {
                    <a asp-page="/Register/Index" class="btn btn-secondary">Register</a>
                    <a asp-page="/Login/Index"
                       class="px-3 py-2 text-white/80 hover:text-white text-sm transition-colors no-underline">Login</a>
                }
            </nav>
        </div>
    </div>
</header>

<div class="min-h-screen flex flex-col">
    <main role="main" class="flex-grow min-h-screen bg-[#F6F1E9]">
        @RenderBody()
    </main>
</div>

<!-- Footer -->
<footer class="footer sm:footer-horizontal bg-[#1C1A17] text-white px-6 py-14">
    <aside>
        <div class="flex items-center gap-2 mb-4">
            <div class="size-8 bg-[#C97C2E] rounded-full flex items-center justify-center">
                <i class="ph-fill ph-heart text-white"></i>
            </div>
            <h3 class="font-bold">Give<span class="text-[#E8C07D]">-AID</span></h3>
        </div>
        <p class="text-white/50 text-sm leading-relaxed mb-5 max-w-xs">A Non-Governmental Organisation established to
            coordinate welfare funding across 48 verified partners and 12 countries.</p>
        <div class="flex gap-3">
            <div class="social-icon">FB</div>
            <div class="social-icon">TW</div>
            <div class="social-icon">IG</div>
            <div class="social-icon">LI</div>
        </div>
    </aside>
    <nav>
        <h6 class="footer-title">Quick Links</h6>
        <a asp-page="/" class="link link-hover">Home</a>
        <a asp-page="/Programmes" class="link link-hover">Programmes</a>
        <a asp-page="/Gallery/Index" class="link link-hover">Gallery</a>
        <a asp-page="/Partners" class="link link-hover">Our Partners</a>
    </nav>
    <nav>
        <h6 class="footer-title">Contact</h6>
        <div class="space-y-2 text-sm text-white/60">
            <p>12, Philanthropy Lane</p>
            <p>Bandra West, Mumbai 400050</p>
            <p>+91 22 4567 8900</p>
            <p>info@give-aid.org</p>
        </div>
    </nav>
</footer>
<footer
    class="footer sm:footer-horizontal bg-[#1C1A17] text-white px-6 py-5 border-t border-white/5 items-center justify-between gap-3 text-xs text-white/30">
    <aside>
        <p>© 2026 Give-AID. All rights reserved.</p>
    </aside>
    <aside class="flex gap-5">
        <span class="hover:text-white/60 cursor-pointer transition-colors">Privacy Policy</span>
        <span class="hover:text-white/60 cursor-pointer transition-colors">Terms of Use</span>
        <span class="hover:text-white/60 cursor-pointer transition-colors">Certificate</span>
    </aside>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", false)
</body>
</html>
